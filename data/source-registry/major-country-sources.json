      "source_registry",
      "fetch_or_snapshot",
      "parse",
      "normalize",
      "promote",
      "build_current_timetable",
      "validate",
      "generated_update_pr"
    ],
    "rank_promotion_required_until_archived": true,
    "a_archived_records_are_skipped_by_promotion": true,
    "no_odds": true,
    "no_payouts": true,
    "no_predictions": true,
    "no_tips": true,
    "no_live_coverage_claim": true,
    "no_full_automation_claim": true
  },
  "source_kinds": [
    "annual",
    "rolling",
    "racecard"
  ],
  "promotion_rules": {
    "D": {
      "goal": "C",
      "try_source_kinds": ["annual", "rolling"],
      "skip_when": ["off_season", "archived", "cancelled_archived"]
    },
    "C": {
      "goal": "B_or_A",
      "try_source_kinds": ["rolling", "racecard"],
      "skip_when": ["archived", "cancelled_archived"]
    },
    "B": {
      "goal": "A",
      "try_source_kinds": ["racecard"],
      "skip_when": ["archived", "cancelled_archived"]
    },
    "A": {
      "goal": "archive_after_final_check",
      "try_source_kinds": ["racecard"],
      "skip_when": ["archived", "cancelled_archived"]
    }
  },
  "lifecycle_statuses": [
    "future",
    "upcoming",
    "race_day",
    "completed",
    "archived",
    "cancelled",
    "cancelled_archived",
    "off_season"
  ],
  "refresh_commands": {
    "annual": "npm run refresh:timetable:annual",
    "rolling": "npm run refresh:timetable:rolling",
    "racecard": "npm run refresh:timetable:racecards",
    "promote": "npm run promote:timetable",
    "archive": "npm run archive:timetable",
    "all": "npm run refresh:timetable"
  },
