{
  "schema_version": "live-broadcast-coverage-v0",
  "description": "Schema-like static structure and initial placeholder records for future official live broadcast and replay availability research. Records are intentionally unaudited until official source research is completed.",
  "allowed_status_values": [
    "official_free",
    "official_account",
    "betting_account",
    "tv_pay",
    "broadcast_partner",
    "replay_available",
    "social_stream",
    "racecourse_only",
    "event_only",
    "geo_restricted",
    "not_verified",
    "none_found",
    "archive_only",
    "unsafe_unofficial"
  ],
  "allowed_confidence_values": [
    "high",
    "medium",
    "low",
    "not_checked"
  ],
  "record_fields": {
    "jurisdiction_id": "Stable jurisdiction identifier used by the project.",
    "country_or_region": "Public country, region, or jurisdiction name.",
    "racing_types": "Array of racing type identifiers covered by the record.",
    "live_status": "Official live broadcast availability status.",
    "replay_status": "Official replay availability status.",
    "provider_name": "Official authority, racecourse, broadcaster, or clearly official partner name, or null when unknown.",
    "official_live_url": "Official live broadcast landing page URL, or null when unknown or not available.",
    "official_replay_url": "Official replay landing page URL, or null when unknown or not available.",
    "requires_login": "Boolean or null when unknown.",
    "requires_betting_account": "Boolean or null when unknown.",
    "requires_paid_tv": "Boolean or null when unknown.",
    "geo_restriction": "Short neutral geographic restriction note, or null when unknown or not applicable.",
    "source_type": "Official source type such as authority, racecourse, broadcaster, official_partner, or official_social.",
    "evidence_urls": "Array of official or clearly official-partner evidence URLs.",
    "confidence": "Research confidence label.",
    "last_checked": "ISO date in YYYY-MM-DD format, or null when not checked.",
    "notes": "Short neutral public-safe note. Do not include betting data, odds, entries, results, payouts, or video mirrors."
  },
