{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whr.badjoke-lab.com/schemas/jra-final-program-intake.schema.json",
  "title": "Where Horses Run JRA final-program intake v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "work_id", "generated_at", "source_stage", "final_confirmation_after", "promotion_eligible", "review", "records", "boundaries"],
  "properties": {
    "schema_version": { "const": "jra-final-program-intake-v1" },
    "work_id": { "const": "WHR-CAL-JAPAN-JRA" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_stage": { "const": "final_program" },
    "source_stage_note": { "type": "string", "minLength": 1 },
    "final_confirmation_after": { "type": "string", "format": "date-time" },
    "review_status": { "enum": ["needs_review", "approved"] },
    "promotion_eligible": { "const": false },
    "review": { "$ref": "#/$defs/review" },
    "records": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/record" } },
    "boundaries": { "$ref": "#/$defs/boundaries" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "time": { "type": "string", "pattern": "^(?:[01]\\d|2[0-3]):[0-5]\\d$" },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "post_time_local", "race_name", "distance_m", "surface", "course_label"],
      "properties": {
        "label": { "type": "string", "pattern": "^Race [1-9][0-9]*$" },
        "post_time_local": { "$ref": "#/$defs/time" },
        "race_name": { "type": ["string", "null"] },
        "distance_m": { "type": ["integer", "null"], "minimum": 1 },
        "surface": { "type": ["string", "null"] },
        "course_label": { "type": ["string", "null"] }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "official_url", "checked_at", "acquisition_method"],
      "properties": {
        "source_id": { "const": "jra-programme" },
        "official_url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "checked_at": { "type": "string", "format": "date-time" },
        "acquisition_method": { "const": "reviewed_final_program_fixture" }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meeting_id", "country_id", "authority_id", "racing_system_id", "racecourse_id", "racecourse_name", "meeting_label_ja", "date", "timezone", "source_stage", "promotion_eligible", "first_race_time_local", "last_race_time_local", "timetable_rows", "source"],
      "properties": {
        "meeting_id": { "$ref": "#/$defs/id" },
        "country_id": { "const": "japan" },
        "authority_id": { "const": "jra" },
        "racing_system_id": { "const": "japan-jra-system" },
        "racecourse_id": { "$ref": "#/$defs/id" },
        "racecourse_name": { "type": "string", "minLength": 1 },
        "meeting_label_ja": { "type": "string", "minLength": 1 },
        "date": { "$ref": "#/$defs/date" },
        "timezone": { "const": "Asia/Tokyo" },
        "source_stage": { "const": "final_program" },
        "promotion_eligible": { "const": false },
        "first_race_time_local": { "$ref": "#/$defs/time" },
        "last_race_time_local": { "$ref": "#/$defs/time" },
        "timetable_rows": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/row" } },
        "source": { "$ref": "#/$defs/source" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewer", "reviewed_at"],
      "properties": {
        "status": { "enum": ["needs_review", "approved"] },
        "reviewer": { "type": ["string", "null"] },
        "reviewed_at": { "type": ["string", "null"], "format": "date-time" },
        "summary": { "type": "string" }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_body_stored", "participant_data_stored", "betting_data_stored", "result_data_stored", "candidate_generated", "canonical_written", "public_projection_written"],
      "properties": {
        "source_body_stored": { "const": false },
        "participant_data_stored": { "const": false },
        "betting_data_stored": { "const": false },
        "result_data_stored": { "const": false },
        "candidate_generated": { "const": false },
        "canonical_written": { "const": false },
        "public_projection_written": { "const": false }
      }
    }
  }
}
