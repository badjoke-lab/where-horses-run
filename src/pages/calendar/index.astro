---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteData } from '../../lib/data';

const timetableData = siteData.generated.timetables;
const generatedTimetableDate = (timetableData.generated_at ?? '').slice(0, 10);
const rangeStartDate = generatedTimetableDate;
const generatedDate = generatedTimetableDate ? new Date(`${generatedTimetableDate}T00:00:00.000Z`) : null;
const rangeEndDate = generatedDate
  ? new Date(Date.UTC(generatedDate.getUTCFullYear(), generatedDate.getUTCMonth(), generatedDate.getUTCDate() + 30))
      .toISOString()
      .slice(0, 10)
  : '';
const calendarRecords = (timetableData.records ?? [])
  .filter((record) => record.date >= rangeStartDate && record.date < rangeEndDate)
  .sort((a, b) => `${a.date}:${a.country_id}:${a.racecourse_id}`.localeCompare(`${b.date}:${b.country_id}:${b.racecourse_id}`));
const recordsByDate = calendarRecords.reduce((groups, record) => {
  groups[record.date] = [...(groups[record.date] ?? []), record];
  return groups;
}, {});
const groupedCalendarRecords = Object.keys(recordsByDate).map((date) => ({ date, records: recordsByDate[date] }));
---

<BaseLayout
  title="30-day safe timetable calendar | Where Horses Run"
  description="Safe timetable records grouped by date for the 30-day calendar range, with official source links as the final confirmation point."
  canonicalPath="/calendar/"
  alternatePath="/ja/calendar/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Calendar</p>
    <h1 id="page-title">30-day safe timetable calendar</h1>
    <p class="hero__summary">
      Safe generated timetable records grouped by date for the next 30 days from the generated timetable date.
      Official source links remain the final confirmation point.
    </p>
  </section>

  <section class="section-grid" aria-label="30-day safe timetable status">
    <article class="card">
      <h2>Status</h2>
      <p><strong>Generated date:</strong> {generatedTimetableDate || 'not listed'}</p>
      <p><strong>Range start:</strong> {rangeStartDate || 'not listed'}</p>
      <p><strong>Range end:</strong> {rangeEndDate || 'not listed'} (exclusive)</p>
      <p><strong>Matching records:</strong> {calendarRecords.length}</p>
      <p><strong>Live fetching:</strong> disabled</p>
    </article>

    <article class="card">
      <h2>Official confirmation</h2>
      <p>Use official source links for final confirmation.</p>
    </article>
  </section>

  <section class="section-grid" aria-label="30-day safe timetable records">
    <article class="card">
      <h2>Records by date</h2>
      {groupedCalendarRecords.length > 0 ? (
        <div>
          {groupedCalendarRecords.map((group) => (
            <section aria-labelledby={`date-${group.date}`}>
              <h3 id={`date-${group.date}`}>{group.date}</h3>
              <ul>
                {group.records.map((record) => (
                  <li>
                    <p><strong>Country:</strong> {record.country_id}</p>
                    <p><strong>Racecourse:</strong> {record.racecourse_name}{record.racecourse_id ? ` (${record.racecourse_id})` : ''}</p>
                    <p><strong>Date:</strong> {record.date}</p>
                    <p><strong>Start time:</strong> {record.start_time_local}</p>
                    <p><strong>Timezone:</strong> {record.timezone}</p>
                    <p><strong>Racing type:</strong> {record.racing_type}</p>
                    <p>
                      <strong>Official source:</strong>{' '}
                      <a href={record.source_url}>{record.source_id}</a>
                    </p>
                    <p><strong>Last checked:</strong> {record.last_checked_at}</p>
                    <p><strong>Status:</strong> {record.status}</p>
                    <p><strong>Confidence:</strong> {record.confidence}</p>
                    <p><strong>Notes:</strong> {Array.isArray(record.notes) ? record.notes.join('; ') : record.notes}</p>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      ) : (
        <div>
          <p>No safe timetable records are listed for the next 30 days yet.</p>
          <p>Use official source links for final confirmation.</p>
          <p>Live fetching: disabled</p>
        </div>
      )}
    </article>
  </section>
</BaseLayout>
