---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteData } from '../../lib/data';

const latest = siteData.generated.latest;
const today = siteData.generated.today;
const tomorrow = siteData.generated.tomorrow;
const calendar30d = siteData.generated.calendar30d;
const fetchStatus = siteData.generated.fetchStatus;

const sourceStatuses = fetchStatus.sources ?? [];
const notes = fetchStatus.notes ?? [];
const todayMeetings = today.meetings ?? [];
const tomorrowMeetings = tomorrow.meetings ?? [];
const calendarMeetings = calendar30d.meetings ?? [];

const isPlaceholder = fetchStatus.status === 'placeholder' || latest.status === 'placeholder';
---

<BaseLayout
  title="Calendar | Where Horses Run"
  description="Generated calendar status, fallback states, and placeholder schedule page for Where Horses Run."
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Calendar</p>
    <h1 id="page-title">Calendar</h1>
    <p class="hero__summary">
      Generated schedule status, freshness, placeholder state, and fallback schedule entries.
    </p>
  </section>

  <section class="section-grid" aria-label="Generated data status">
    <article class="card">
      <h2>Generated status</h2>
      <p><strong>Status:</strong> {fetchStatus.status}</p>
      <p><strong>Generated at:</strong> {fetchStatus.generated_at}</p>
      <p><strong>Latest status:</strong> {latest.status}</p>
    </article>

    <article class="card">
      <h2>Data boundary</h2>
      <p>
        {isPlaceholder
          ? 'This is placeholder data. Live fetching and parser workflows have not started.'
          : 'Generated data is available, but official sources remain the final confirmation point.'}
      </p>
    </article>

    <article class="card">
      <h2>Official confirmation</h2>
      <p>
        Always confirm race days, race times, entries, results, and payouts with official sources.
      </p>
    </article>
  </section>

  <section class="section-grid" aria-label="Schedule fallback sections">
    <article class="card">
      <h2>Today</h2>
      <p><strong>Generated:</strong> {today.generated_at}</p>
      {todayMeetings.length > 0 ? (
        <ul>
          {todayMeetings.map((meeting) => (
            <li>
              <strong>{meeting.track_name}</strong> — {meeting.local_date} / {meeting.status}
            </li>
          ))}
        </ul>
      ) : (
        <p>No generated meetings are listed for today. Use official sources for confirmation.</p>
      )}
    </article>

    <article class="card">
      <h2>Tomorrow</h2>
      <p><strong>Generated:</strong> {tomorrow.generated_at}</p>
      {tomorrowMeetings.length > 0 ? (
        <ul>
          {tomorrowMeetings.map((meeting) => (
            <li>
              <strong>{meeting.track_name}</strong> — {meeting.local_date} / {meeting.status}
            </li>
          ))}
        </ul>
      ) : (
        <p>No generated meetings are listed for tomorrow. Use official sources for confirmation.</p>
      )}
    </article>

    <article class="card">
      <h2>30-day fallback</h2>
      <p><strong>Generated:</strong> {calendar30d.generated_at}</p>
      <p><strong>Range:</strong> {calendar30d.start_date_utc} to {calendar30d.end_date_utc}</p>
      {calendarMeetings.length > 0 ? (
        <ul>
          {calendarMeetings.map((meeting) => (
            <li>
              <strong>{meeting.track_name}</strong> — {meeting.local_date} / {meeting.status}
            </li>
          ))}
        </ul>
      ) : (
        <p>No generated meetings are listed for the 30-day fallback range.</p>
      )}
    </article>
  </section>

  <section class="section-grid" aria-label="Generated files and notes">
    <article class="card">
      <h2>Generated files</h2>
      <p>{latest.today_file}</p>
      <p>{latest.tomorrow_file}</p>
      <p>{latest.calendar_30d_file}</p>
      <p>{latest.fetch_status_file}</p>
    </article>

    <article class="card">
      <h2>Source status</h2>
      {sourceStatuses.length > 0 ? (
        <ul>
          {sourceStatuses.map((source) => (
            <li>
              <strong>{source.source_id}</strong>: {source.status}
            </li>
          ))}
        </ul>
      ) : (
        <p>No source status entries are listed yet.</p>
      )}
    </article>

    <article class="card">
      <h2>Notes</h2>
      {notes.length > 0 ? (
        <ul>
          {notes.map((note) => <li>{note}</li>)}
        </ul>
      ) : (
        <p>No generated data notes are listed yet.</p>
      )}
    </article>
  </section>
</BaseLayout>
