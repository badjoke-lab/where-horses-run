---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimetableMeetingList from '../../components/TimetableMeetingList.astro';
import { getGroupedTimetableMeetingRows } from '../../data/timetableMeetingRows';

const groupedCalendarRecords = getGroupedTimetableMeetingRows();
---

<BaseLayout
  title="June 2026 Calendar | Where Horses Run"
  description="A simple date-first meeting calendar for June 2026, with one official source link per meeting and race timetable links only where race-by-race times are available."
  canonicalPath="/calendar/"
  alternatePath="/ja/calendar/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Calendar</p>
    <h1 id="page-title">June 2026 Calendar</h1>
    <p class="hero__summary">
      Meetings grouped by date. Rank controls how much timing detail is shown; official sources remain the final confirmation point.
    </p>
  </section>

  <section aria-label="June 2026 meetings by date">
    <TimetableMeetingList
      groups={groupedCalendarRecords}
      emptyLabel="No June 2026 meetings are listed yet. Use official source links for final confirmation."
    />
  </section>
</BaseLayout>
