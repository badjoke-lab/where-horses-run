---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalendarDateStatus from '../../components/CalendarDateStatus.astro';
import TimetableMeetingList from '../../components/TimetableMeetingList.astro';
import {
  getCurrentCalendarWindowGroups,
  getTimetableDataState,
  getTimetableDateContext,
} from '../../data/timetableMeetingRows';

const context = getTimetableDateContext();
const dataState = getTimetableDataState(context);
const groups = getCurrentCalendarWindowGroups(context);
---

<BaseLayout
  title={`30-day racing calendar | Where Horses Run`}
  description={`Reviewed public meetings from ${context.windowStart} through ${context.windowEndInclusive}.`}
  canonicalPath="/calendar/"
  alternatePath="/ja/calendar/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Calendar</p>
    <h1 id="page-title">30-day racing calendar</h1>
    <p class="hero__summary">
      Reviewed meetings from {context.windowStart} through {context.windowEndInclusive}, using {context.timeZone} as the reference timezone.
    </p>
  </section>

  <CalendarDateStatus context={context} dataState={dataState} />

  <section aria-label="Rolling 30-day meeting list">
    <TimetableMeetingList
      groups={groups}
      emptyLabel={`No reviewed public meetings fall between ${context.windowStart} and ${context.windowEndInclusive}. Check official sources for current information.`}
    />
  </section>
</BaseLayout>
