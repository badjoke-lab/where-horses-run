---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TimetableMeetingList from '../../../components/TimetableMeetingList.astro';
import { getGroupedTimetableMeetingRows } from '../../../data/timetableMeetingRows';

const groupedCalendarRecords = getGroupedTimetableMeetingRows();
---

<BaseLayout
  title="2026年6月 開催カレンダー | 競馬どこ？"
  description="2026年6月の開催情報を日付別に1開催1行で表示し、詳細情報と公式ソースへのリンクを案内します。"
  lang="ja"
  canonicalPath="/ja/calendar/"
  alternatePath="/calendar/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Calendar</p>
    <h1 id="page-title">2026年6月 開催カレンダー</h1>
    <p class="hero__summary">
      開催情報を日付別に表示します。表示ランクに応じて時刻情報を出し分け、最終確認先として公式ソースを案内します。
    </p>
  </section>

  <section aria-label="2026年6月の開催一覧">
    <TimetableMeetingList
      groups={groupedCalendarRecords}
      lang="ja"
      emptyLabel="2026年6月の開催情報はまだありません。最終確認には公式ソースを使用してください。"
    />
  </section>
</BaseLayout>
