---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CalendarDateStatus from '../../../components/CalendarDateStatus.astro';
import TimetableMeetingList from '../../../components/TimetableMeetingList.astro';
import { getCurrentCalendarWindowGroups, getTimetableDataState, getTimetableDateContext } from '../../../data/timetableMeetingRows';

const context = getTimetableDateContext();
const dataState = getTimetableDataState(context);
const groupedCalendarRecords = getCurrentCalendarWindowGroups(context);
---

<BaseLayout
  title="30日間の開催カレンダー | 競馬どこ？"
  description="基準日から30日間の確認済み公開開催情報を日付別に案内します。"
  lang="ja"
  canonicalPath="/ja/calendar/"
  alternatePath="/calendar/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Calendar</p>
    <h1 id="page-title">30日間の開催カレンダー</h1>
    <p class="hero__summary">
      {context.windowStart}から{context.windowEndInclusive}までの確認済み開催を表示します。基準タイムゾーンは{context.timeZone}です。
    </p>
  </section>

  <CalendarDateStatus context={context} dataState={dataState} lang="ja" />

  <section aria-label="30日間の開催一覧">
    <TimetableMeetingList
      groups={groupedCalendarRecords}
      lang="ja"
      emptyLabel="この30日間に確認済み公開開催はありません。最新情報は公式ソースで確認してください。"
    />
  </section>
</BaseLayout>
