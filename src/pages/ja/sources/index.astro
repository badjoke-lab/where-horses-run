---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { siteData, getCountries } from '../../../lib/data';

const sources = siteData.sources;
const countries = getCountries();
const countryById = new Map(countries.map((country) => [country.id, country]));
const sourceGroups = countries
  .map((country) => ({
    country,
    sources: sources.filter((source) => source.country_id === country.id)
  }))
  .filter((group) => group.sources.length > 0);
---

<BaseLayout
  title="ソース | 競馬どこ？"
  description="競馬どこ？ で参照する公式・参考ソースを一覧できます。"
  lang="ja"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Sources</p>
    <h1 id="page-title">ソース</h1>
    <p class="hero__summary">
      国・地域や開催情報の確認に使うソース項目を一覧できます。
    </p>
  </section>

  <section class="section-grid" aria-label="国別ソース">
    <article class="card">
      <h2>国・地域別に見る</h2>
      <ul>
        {sourceGroups.map(({ country, sources }) => (
          <li><a href={`/ja/sources/${country.slug}/`}>{country.name_ja}</a> — {sources.length}件</li>
        ))}
      </ul>
    </article>
  </section>

  <section class="section-grid" aria-label="ソース一覧">
    {sources.map((source) => {
      const country = countryById.get(source.country_id);
      return (
        <article class="card">
          <h2><a href={source.url}>{source.id}</a></h2>
          <p>{country ? <a href={`/ja/sources/${country.slug}/`}>{country.name_ja}</a> : source.country_id}</p>
          <p><strong>種別:</strong> {source.source_type}</p>
          <p><strong>データ:</strong> {source.data_type}</p>
          <p><strong>自動化:</strong> {source.auto_level}</p>
        </article>
      );
    })}
  </section>
</BaseLayout>
