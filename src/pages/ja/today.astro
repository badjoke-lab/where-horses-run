---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimetableMeetingList from '../../components/TimetableMeetingList.astro';
import { getCurrentTimetableDate, getTimetableMeetingRowsForDate } from '../../data/timetableMeetingRows';

const currentTimetableDate = getCurrentTimetableDate();
const todayRecords = getTimetableMeetingRowsForDate(currentTimetableDate);
---

<BaseLayout
  title="今日の開催時刻表 | 競馬どこ？"
  description="今日の開催一覧を1開催1行で表示し、利用可能な時刻情報、詳細ページ、公式ソースを案内します。"
  lang="ja"
  canonicalPath="/ja/today/"
  alternatePath="/today/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Today</p>
    <h1 id="page-title">今日の開催時刻表</h1>
    <p class="hero__summary">
      {currentTimetableDate} の開催情報です。表示ランクに応じて時刻情報を出し分けます。
    </p>
  </section>

  <section aria-label="今日の開催一覧">
    <TimetableMeetingList
      records={todayRecords}
      date={currentTimetableDate}
      lang="ja"
      emptyLabel="今日の開催情報はまだありません。最終確認には公式ソースを使用してください。"
    />
  </section>
</BaseLayout>
