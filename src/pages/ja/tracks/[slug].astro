---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  getCountries,
  getGlossaryEntries,
  getRacecourseBySlug,
  getRacecourses,
  siteData
} from '../../../lib/data';
import { getRacingTypeById } from '../../../lib/racingTypes';

export function getStaticPaths() {
  return getRacecourses().map((track) => ({ params: { slug: track.slug } }));
}

const { slug } = Astro.params;
const track = getRacecourseBySlug(slug ?? '');

if (!track) {
  return Astro.redirect('/ja/tracks/');
}

const profile = track as any;
const countries = getCountries();
const country = countries.find((entry) => entry.id === track.country_id);
const countryHref = country ? `/ja/countries/${country.slug}/` : '/ja/countries/';
const countrySourceHref = country ? `/ja/sources/${country.slug}/` : '/ja/sources/';
const calendarHref = country ? `/ja/countries/${country.slug}/` : '/ja/calendar/';
const glossaryById = new Map(getGlossaryEntries().map((entry) => [entry.id, entry]));
const sourcesById = new Map(siteData.sources.map((source) => [source.id, source]));

const formatValue = (value: unknown) => {
  if (value === null || value === undefined || value === '') return '未確認';
  if (Array.isArray(value)) return value.length > 0 ? value.join(', ') : '未確認';
  return String(value);
};

const formatNumber = (value: unknown) => typeof value === 'number' ? value.toLocaleString('ja-JP') : '未確認';
const formatMeters = (value: unknown) => typeof value === 'number' ? `${value.toLocaleString('ja-JP')}m` : '未確認';

const directionLabel = (value: unknown) => {
  const labels: Record<string, string> = {
    'left-handed': '左回り',
    'right-handed': '右回り',
    straight: '直線',
    unknown: '未確認'
  };
  return typeof value === 'string' ? labels[value] ?? value : '未確認';
};

const statusLabel = (value: unknown) => {
  const labels: Record<string, string> = {
    racing_today: '本日開催あり',
    no_racing_today: '本日開催なし',
    unknown: '未確認',
    verified: '確認済み',
    partial: '一部確認済み',
    secondary: '二次情報',
    stale: '再確認が必要',
    failed: '取得失敗',
    'official-link-only': '公式リンク確認',
    link_first: 'リンク優先'
  };
  return typeof value === 'string' ? labels[value] ?? value : '未確認';
};

const toRecord = (value: unknown): Record<string, any> => {
  if (!value || typeof value !== 'object' || Array.isArray(value)) return {};
  return value as Record<string, any>;
};

const firstValue = (record: unknown, keys: string[]) => {
  const row = toRecord(record);
  for (const key of keys) {
    if (row[key] !== null && row[key] !== undefined && row[key] !== '') return row[key];
  }
  return null;
};

const formatRecordFields = (record: unknown, fields: Array<[string, string[]]>) => {
  const parts = fields
    .map(([label, keys]) => {
      const value = firstValue(record, keys);
      return value === null ? null : `${label}: ${String(value)}`;
    })
    .filter(Boolean);
  return parts.length ? parts.join(' ・ ') : '詳細は整形待ちです。';
};

const formatDistanceList = (value: unknown) => {
  if (!Array.isArray(value) || value.length === 0) return '未確認';
  return value.map((distance) => `${distance}m`).join(', ');
};

const officialLinks = track.official_links ?? [];
const relatedTerms = track.related_terms ?? [];
const relatedSources = track.related_sources ?? [];
const operator = toRecord(profile.operator);
const capacity = toRecord(profile.capacity_profile);
const courseLayout = toRecord(profile.course_layout);
const raceDistanceProfile = toRecord(profile.race_distance_profile);
const visitorLinks = toRecord(profile.visitor_links);

const primaryScheduleUrl = typeof visitorLinks.official_schedule === 'string'
  ? visitorLinks.official_schedule
  : officialLinks.find((link) => link.link_type === 'schedule')?.url ?? officialLinks[0]?.url;
const primaryVenueUrl = typeof visitorLinks.official_racecourse === 'string'
  ? visitorLinks.official_racecourse
  : officialLinks.find((link) => link.link_type === 'official')?.url ?? officialLinks[0]?.url;
const primaryCourseUrl = typeof visitorLinks.official_course_details === 'string'
  ? visitorLinks.official_course_details
  : officialLinks.find((link) => link.url.includes('course_details'))?.url;

const meetingFields: Array<[string, string[]]> = [
  ['日付', ['date', 'local_date', 'meeting_date']],
  ['1R', ['first_post', 'first_race_time', 'first_race']],
  ['最終', ['last_race_time', 'last_race']],
  ['レース数', ['race_count', 'races']],
  ['状態', ['status']]
];
const raceConditionFields: Array<[string, string[]]> = [
  ['日付', ['date', 'local_date']],
  ['R', ['race_number', 'race_no', 'race']],
  ['時刻', ['post_time', 'start_time', 'time']],
  ['馬場', ['surface']],
  ['距離', ['distance', 'distance_m']],
  ['種別', ['race_type', 'type']]
];
const notableRaceFields: Array<[string, string[]]> = [
  ['名称', ['name_ja', 'name', 'race_name']],
  ['格付け', ['grade']],
  ['馬場', ['surface']],
  ['距離', ['distance_m', 'distance']],
  ['時期', ['season', 'month']],
  ['ソース', ['official_link', 'source_url', 'url']]
];

const courseGroups = [
  ['芝コース', courseLayout.turf_courses],
  ['ダートコース', courseLayout.dirt_courses],
  ['障害コース', courseLayout.jump_courses],
  ['オールウェザーコース', courseLayout.all_weather_courses],
  ['ハーネスコース', courseLayout.harness_courses],
  ['ばんえいコース', courseLayout.banei_courses]
].filter(([, rows]) => Array.isArray(rows) && rows.length > 0) as Array<[string, any[]]>;

const fallbackCourseRows = [
  ['芝1周', track.course_profile?.turf_circumference_m],
  ['ダート1周', track.course_profile?.dirt_circumference_m],
  ['直線', track.course_profile?.home_straight_m]
].filter(([, value]) => typeof value === 'number');

const visitorLinkRows = [
  ['公式競馬場ページ', visitorLinks.official_racecourse],
  ['公式開催予定', visitorLinks.official_schedule],
  ['公式コース詳細', visitorLinks.official_course_details],
  ['公式アクセス', visitorLinks.official_access],
  ['公式レースカード', visitorLinks.official_racecard],
  ['公式結果', visitorLinks.official_results]
].filter(([, url]) => typeof url === 'string' && url.length > 0) as Array<[string, string]>;

const overview = profile.overview_ja ?? track.course_profile?.course_notes_ja ?? 'この競馬場ページは、公式またはソース安全な競馬情報をもとに整備中です。';
---

<BaseLayout title={`${track.name_ja} | 競馬場 | 競馬どこ？`} description={`${track.name_ja} の規模、コース構造、開催予定導線、公式リンク、関連用語をまとめた競馬場ページです。`} lang="ja">
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Racecourse profile</p>
    <h1 id="page-title">{track.name_ja}</h1>
    <p class="hero__summary">
      {track.name_local && track.name_local !== track.name_ja ? `${track.name_local} · ` : ''}
      {country ? country.name_ja : track.country_id} / {track.city}
    </p>
    <p>{overview}</p>
    <p>
      {primaryScheduleUrl ? <a href={primaryScheduleUrl}>公式開催予定を見る</a> : <a href={calendarHref}>カレンダーを見る</a>}
      {' ・ '}
      {primaryVenueUrl ? <a href={primaryVenueUrl}>公式競馬場ページ</a> : <a href={countrySourceHref}>国別ソース一覧</a>}
      {primaryCourseUrl ? <><span>{' ・ '}</span><a href={primaryCourseUrl}>公式コース詳細</a></> : null}
    </p>
  </section>

  <section class="section-grid" aria-label="基本情報と開催導線">
    <article class="card">
      <h2>基本情報</h2>
      <p><strong>国:</strong> <a href={countryHref}>{country ? country.name_ja : track.country_id}</a></p>
      <p><strong>都市 / 地域:</strong> {track.city} / {formatValue(track.region)}</p>
      <p><strong>タイムゾーン:</strong> {track.timezone}</p>
      <p><strong>運営者:</strong> {formatValue(operator.name)}{operator.type ? ` (${operator.type})` : ''}</p>
      <p><strong>状態:</strong> {track.status}</p>
      <p><strong>馬場:</strong> {formatValue(track.surfaces)}</p>
      <p><strong>回り:</strong> {directionLabel(track.direction)}</p>
      <p><strong>代表芝コース長:</strong> {formatMeters(track.course_profile?.turf_circumference_m)}</p>
      <p><strong>直線:</strong> {formatMeters(courseLayout.home_straight_m ?? track.course_profile?.home_straight_m)}</p>
    </article>

    <article class="card">
      <h2>規模感</h2>
      <p><strong>収容人数:</strong> {formatNumber(capacity.total_capacity)}</p>
      <p><strong>座席数:</strong> {formatNumber(capacity.seating_capacity)}</p>
      <p><strong>立見等:</strong> {formatNumber(capacity.standing_capacity)}</p>
      <p><strong>確認状態:</strong> {statusLabel(capacity.status)}</p>
      <p>{capacity.scale_note_ja ?? '収容人数はまだ確認できていません。'}</p>
      {capacity.source_url ? <p><a href={capacity.source_url}>収容人数ソース</a></p> : null}
    </article>

    <article class="card">
      <h2>開催予定への導線</h2>
      <p><strong>今日:</strong> {statusLabel(track.schedule_summary?.today_status)}</p>
      <p><strong>次回開催:</strong> {formatValue(track.schedule_summary?.next_meeting_date)}</p>
      <p><strong>予定データ:</strong> {statusLabel(track.schedule_summary?.status)}</p>
      <p><strong>最終確認:</strong> {formatValue(track.schedule_summary?.last_checked)}</p>
      <p>{primaryScheduleUrl ? <a href={primaryScheduleUrl}>公式開催予定を確認</a> : <a href={calendarHref}>取得済みカレンダーを見る</a>}</p>
    </article>
  </section>

  <section class="section-grid" aria-label="競馬種別と直近予定">
    <article class="card">
      <h2>競馬種別</h2>
      <ul>
        {track.racing_types.map((typeId) => {
          const type = getRacingTypeById(typeId);
          return <li>{type ? <a href={`/ja/types/${type.slug}/`}>{type.name_ja}</a> : typeId}</li>;
        })}
      </ul>
    </article>

    <article class="card">
      <h2>直近の開催予定</h2>
      {track.schedule_summary?.upcoming_meetings?.length ? (
        <ul>
          {track.schedule_summary.upcoming_meetings.map((meeting) => (
            <li>{formatRecordFields(meeting, meetingFields)}</li>
          ))}
        </ul>
      ) : (
        <p>この競馬場の確認済み開催予定行はまだありません。最終確認は公式開催予定で行ってください。</p>
      )}
    </article>

    <article class="card">
      <h2>直近開催のレース条件</h2>
      {track.distance_profile?.upcoming_conditions?.length ? (
        <ul>
          {track.distance_profile.upcoming_conditions.map((condition) => (
            <li>{formatRecordFields(condition, raceConditionFields)}</li>
          ))}
        </ul>
      ) : (
        <p>確認済みのレース条件行はまだありません。出走表・オッズ・結果・払戻・全文レースカードはここでは再掲載しません。</p>
      )}
    </article>
  </section>

  <section class="section-grid" aria-label="コース構造と実施距離">
    <article class="card">
      <h2>コース構造</h2>
      {courseGroups.length ? (
        <div>
          {courseGroups.map(([label, rows]) => (
            <div>
              <h3>{label}</h3>
              <ul>
                {rows.map((course) => (
                  <li>
                    <strong>{course.label}</strong>
                    {' — '}{formatMeters(course.circumference_m)}
                    {course.direction ? ` ・ ${directionLabel(course.direction)}` : ''}
                    {course.surface ? ` ・ ${course.surface}` : ''}
                    {course.note_ja ? <><br /><span>{course.note_ja}</span></> : null}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <div>
          <p>{track.course_profile?.course_notes_ja ?? 'コース構造は公式ソース確認後に反映します。'}</p>
          {fallbackCourseRows.length ? <ul>{fallbackCourseRows.map(([label, value]) => <li><strong>{label}:</strong> {formatMeters(value)}</li>)}</ul> : null}
        </div>
      )}
      <p><strong>内外回りメモ:</strong> {courseLayout.inner_outer_note_ja ?? (track.course_profile?.has_inner_outer_courses === null ? '未確認' : String(track.course_profile?.has_inner_outer_courses))}</p>
      <p><strong>構造データ:</strong> {statusLabel(courseLayout.status ?? track.data_status?.course_profile)}</p>
    </article>

    <article class="card">
      <h2>実施レース距離</h2>
      <p>この欄はコース1周距離ではなく、実際に使われるレース距離を扱います。</p>
      <p><strong>芝:</strong> {formatDistanceList(raceDistanceProfile.turf_distances_m)}</p>
      <p><strong>ダート:</strong> {formatDistanceList(raceDistanceProfile.dirt_distances_m)}</p>
      <p><strong>障害:</strong> {formatDistanceList(raceDistanceProfile.jump_distances_m)}</p>
      <p><strong>オールウェザー:</strong> {formatDistanceList(raceDistanceProfile.all_weather_distances_m)}</p>
      <p><strong>ハーネス:</strong> {formatDistanceList(raceDistanceProfile.harness_distances_m)}</p>
      <p><strong>確認状態:</strong> {statusLabel(raceDistanceProfile.status)}</p>
    </article>
  </section>

  <section class="section-grid" aria-label="代表レース・開催シーズン・公式リンク">
    <article class="card">
      <h2>代表レース</h2>
      {track.notable_races?.length ? (
        <ul>
          {track.notable_races.map((race) => (
            <li>{formatRecordFields(race, notableRaceFields)}</li>
          ))}
        </ul>
      ) : (
        <p>代表レース情報はまだ登録されていません。将来追加する場合は公式またはソース安全なページへリンクします。</p>
      )}
    </article>

    <article class="card">
      <h2>開催シーズン</h2>
      <p>{track.seasonality?.summary_ja ?? '開催シーズンは公式ソース確認後に反映します。'}</p>
      <p><strong>状態:</strong> {statusLabel(track.seasonality?.status)}</p>
    </article>

    <article class="card">
      <h2>公式・来場関連リンク</h2>
      {visitorLinkRows.length ? (
        <ul>
          {visitorLinkRows.map(([label, url]) => <li><a href={url}>{label}</a></li>)}
        </ul>
      ) : null}
      {officialLinks.length ? (
        <ul>
          {officialLinks.map((link) => (
            <li>
              <a href={link.url}>{link.label_ja}</a>
              <br />
              <span>種別: {link.link_type} / Source: {link.source_id}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p>この競馬場に紐づく公式リンクはまだありません。</p>
      )}
    </article>
  </section>

  <section class="section-grid" aria-label="データ状態と関連ページ">
    <article class="card">
      <h2>データ状態</h2>
      <p><strong>コース:</strong> {statusLabel(track.data_status?.course_profile)}</p>
      <p><strong>予定:</strong> {statusLabel(track.data_status?.schedule)}</p>
      <p><strong>ソース導線:</strong> {statusLabel(track.data_status?.source_status)}</p>
      <p><strong>収容人数:</strong> {statusLabel(capacity.status)}</p>
      <p><strong>実施距離:</strong> {statusLabel(raceDistanceProfile.status)}</p>
      <p><strong>最終確認:</strong> {formatValue(track.data_status?.last_checked)}</p>
      <p>Where Horses Run / 競馬どこ？ は公式ソースへの導線を提供しますが、出走表・オッズ・結果・払戻・予想・完全なレースカードは再掲載しません。</p>
    </article>

    <article class="card">
      <h2>関連学習</h2>
      <p><a href={countryHref}>国ページを開く</a></p>
      {relatedTerms.length ? (
        <ul>
          {relatedTerms.map((termId) => {
            const term = glossaryById.get(termId);
            return <li>{term ? <a href={`/ja/glossary/${term.slug}/`}>{term.term_ja}</a> : termId}</li>;
          })}
        </ul>
      ) : (
        <p>関連用語はまだありません。</p>
      )}
    </article>

    <article class="card">
      <h2>関連ソース</h2>
      <p><a href={countrySourceHref}>国別ソース一覧を開く</a></p>
      {relatedSources.length ? (
        <ul>
          {relatedSources.map((sourceId) => {
            const source = sourcesById.get(sourceId);
            return <li>{source ? <a href={source.url}>{source.id}</a> : sourceId}</li>;
          })}
        </ul>
      ) : (
        <p>関連ソースはまだありません。</p>
      )}
    </article>
  </section>

  <p><a href="/ja/tracks/">戻る</a></p>
</BaseLayout>
