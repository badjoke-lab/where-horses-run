---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  getCountries,
  getGlossaryEntries,
  getRacecourseBySlug,
  getRacecourses,
  siteData
} from '../../../lib/data';
import { getRacingTypeById } from '../../../lib/racingTypes';

export function getStaticPaths() {
  return getRacecourses().map((track) => ({ params: { slug: track.slug } }));
}

const { slug } = Astro.params;
const track = getRacecourseBySlug(slug ?? '');

if (!track) {
  return Astro.redirect('/ja/tracks/');
}

const profile = track as any;
const countries = getCountries();
const country = countries.find((entry) => entry.id === track.country_id);
const countryHref = country ? `/ja/countries/${country.slug}/` : '/ja/countries/';
const countrySourceHref = country ? `/ja/sources/${country.slug}/` : '/ja/sources/';
const calendarHref = country ? `/ja/countries/${country.slug}/` : '/ja/calendar/';
const glossaryById = new Map(getGlossaryEntries().map((entry) => [entry.id, entry]));
const sourcesById = new Map(siteData.sources.map((source) => [source.id, source]));

const formatValue = (value: unknown) => {
  if (value === null || value === undefined || value === '') return '未掲載';
  if (Array.isArray(value)) return value.length > 0 ? value.join(', ') : '未掲載';
  return String(value);
};

const formatNumber = (value: unknown) => typeof value === 'number' ? value.toLocaleString('ja-JP') : '未掲載';
const formatMeters = (value: unknown) => typeof value === 'number' ? `${value.toLocaleString('ja-JP')}m` : '未掲載';

const directionLabel = (value: unknown) => {
  const labels: Record<string, string> = {
    'left-handed': '左回り',
    'right-handed': '右回り',
    straight: '直線',
    unknown: '未掲載'
  };
  return typeof value === 'string' ? labels[value] ?? value : '未掲載';
};

const statusLabel = (value: unknown) => {
  const labels: Record<string, string> = {
    racing_today: '本日開催あり',
    no_racing_today: '本日開催なし',
    unknown: '未確認',
    verified: '確認済み',
    partial: '一部確認済み',
    secondary: '二次情報',
    stale: '再確認が必要',
    failed: '利用不可',
    'official-link-only': 'リンク確認',
    link_first: 'リンク優先'
  };
  return typeof value === 'string' ? labels[value] ?? value : '未掲載';
};

const toRecord = (value: unknown): Record<string, any> => {
  if (!value || typeof value !== 'object' || Array.isArray(value)) return {};
  return value as Record<string, any>;
};

const firstValue = (record: unknown, keys: string[]) => {
  const row = toRecord(record);
  for (const key of keys) {
    if (row[key] !== null && row[key] !== undefined && row[key] !== '') return row[key];
  }
  return null;
};

const formatRecordFields = (record: unknown, fields: Array<[string, string[]]>) => {
  const parts = fields
    .map(([label, keys]) => {
      const value = firstValue(record, keys);
      return value === null ? null : `${label}: ${String(value)}`;
    })
    .filter(Boolean);
  return parts.length ? parts.join(' ・ ') : '詳細は今後追加します。';
};

const formatDistanceList = (value: unknown) => {
  if (!Array.isArray(value) || value.length === 0) return null;
  return value.map((distance) => `${distance}m`).join(', ');
};

const officialLinks = track.official_links ?? [];
const relatedTerms = track.related_terms ?? [];
const relatedSources = track.related_sources ?? [];
const operator = toRecord(profile.operator);
const capacity = toRecord(profile.capacity_profile);
const courseLayout = toRecord(profile.course_layout);
const raceDistanceProfile = toRecord(profile.race_distance_profile);
const visitorLinks = toRecord(profile.visitor_links);
const upcomingMeetings = track.schedule_summary?.upcoming_meetings ?? [];
const upcomingConditions = track.distance_profile?.upcoming_conditions ?? [];

const primaryScheduleUrl = typeof visitorLinks.official_schedule === 'string'
  ? visitorLinks.official_schedule
  : officialLinks.find((link) => link.link_type === 'schedule')?.url ?? officialLinks[0]?.url;
const primaryVenueUrl = typeof visitorLinks.official_racecourse === 'string'
  ? visitorLinks.official_racecourse
  : officialLinks.find((link) => link.link_type === 'official')?.url ?? officialLinks[0]?.url;
const primaryCourseUrl = typeof visitorLinks.official_course_details === 'string'
  ? visitorLinks.official_course_details
  : officialLinks.find((link) => link.url.includes('course_details'))?.url;

const meetingFields: Array<[string, string[]]> = [
  ['日付', ['date', 'local_date', 'meeting_date']],
  ['1R', ['first_post', 'first_race_time', 'first_race']],
  ['最終', ['last_race_time', 'last_race']],
  ['レース数', ['race_count', 'races']],
  ['状態', ['status']]
];
const raceConditionFields: Array<[string, string[]]> = [
  ['日付', ['date', 'local_date']],
  ['R', ['race_number', 'race_no', 'race']],
  ['時刻', ['post_time', 'start_time', 'time']],
  ['馬場', ['surface']],
  ['距離', ['distance', 'distance_m']],
  ['種別', ['race_type', 'type']]
];

const courseGroups = [
  ['芝コース', courseLayout.turf_courses],
  ['ダートコース', courseLayout.dirt_courses],
  ['障害コース', courseLayout.jump_courses],
  ['オールウェザーコース', courseLayout.all_weather_courses],
  ['ハーネスコース', courseLayout.harness_courses],
  ['ばんえいコース', courseLayout.banei_courses]
].filter(([, rows]) => Array.isArray(rows) && rows.length > 0) as Array<[string, any[]]>;

const fallbackCourseRows = [
  ['芝1周', track.course_profile?.turf_circumference_m],
  ['ダート1周', track.course_profile?.dirt_circumference_m],
  ['直線', track.course_profile?.home_straight_m]
].filter(([, value]) => typeof value === 'number');

const raceDistanceRows = [
  ['芝', raceDistanceProfile.turf_distances_m],
  ['ダート', raceDistanceProfile.dirt_distances_m],
  ['障害', raceDistanceProfile.jump_distances_m],
  ['オールウェザー', raceDistanceProfile.all_weather_distances_m],
  ['ハーネス', raceDistanceProfile.harness_distances_m]
]
  .map(([label, value]) => [label, formatDistanceList(value)] as const)
  .filter(([, value]) => value);

const visitorLinkRows = [
  ['競馬場ページ', visitorLinks.official_racecourse],
  ['開催予定', visitorLinks.official_schedule],
  ['コース詳細', visitorLinks.official_course_details],
  ['アクセス', visitorLinks.official_access],
  ['レースカード', visitorLinks.official_racecard],
  ['結果', visitorLinks.official_results]
].filter(([, url]) => typeof url === 'string' && url.length > 0) as Array<[string, string]>;

const fallbackOfficialRows = officialLinks.map((link) => [link.label_ja, link.url] as [string, string]);
const linkRows = visitorLinkRows.length ? visitorLinkRows : fallbackOfficialRows;
const overview = profile.overview_ja ?? track.course_profile?.course_notes_ja ?? 'このページでは、競馬場の基本情報、コース情報、開催予定へのリンクを整理しています。';
const hasCapacity = typeof capacity.total_capacity === 'number' || typeof capacity.seating_capacity === 'number' || typeof capacity.standing_capacity === 'number';
---

<BaseLayout title={`${track.name_ja} | 競馬場 | 競馬どこ？`} description={`${track.name_ja} の規模、コース構造、開催予定へのリンク、関連用語をまとめた競馬場ページです。`} lang="ja">
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">競馬場プロフィール</p>
    <h1 id="page-title">{track.name_ja}</h1>
    <p class="hero__summary">
      {track.name_local && track.name_local !== track.name_ja ? `${track.name_local} · ` : ''}
      {country ? country.name_ja : track.country_id} / {track.city}
    </p>
    <p>{overview}</p>
    <p>
      {primaryScheduleUrl ? <a href={primaryScheduleUrl}>開催予定</a> : <a href={calendarHref}>カレンダー</a>}
      {' ・ '}
      {primaryVenueUrl ? <a href={primaryVenueUrl}>競馬場ページ</a> : <a href={countrySourceHref}>ソース一覧</a>}
      {primaryCourseUrl ? <><span>{' ・ '}</span><a href={primaryCourseUrl}>コース詳細</a></> : null}
    </p>
  </section>

  <section class="section-grid" aria-label="競馬場の基本情報">
    <article class="card">
      <h2>基本情報</h2>
      <p><strong>国:</strong> <a href={countryHref}>{country ? country.name_ja : track.country_id}</a></p>
      <p><strong>都市 / 地域:</strong> {track.city} / {formatValue(track.region)}</p>
      <p><strong>タイムゾーン:</strong> {track.timezone}</p>
      <p><strong>運営:</strong> {formatValue(operator.name)}</p>
      <p><strong>状態:</strong> {track.status}</p>
      <p><strong>馬場:</strong> {formatValue(track.surfaces)}</p>
      <p><strong>回り:</strong> {directionLabel(track.direction)}</p>
      <p><strong>代表コース長:</strong> 芝 {formatMeters(track.course_profile?.turf_circumference_m)} / ダート {formatMeters(track.course_profile?.dirt_circumference_m)}</p>
      <p><strong>直線:</strong> {formatMeters(courseLayout.home_straight_m ?? track.course_profile?.home_straight_m)}</p>
    </article>

    {hasCapacity ? (
      <article class="card">
        <h2>規模感</h2>
        <p><strong>収容人数:</strong> {formatNumber(capacity.total_capacity)}</p>
        <p><strong>座席数:</strong> {formatNumber(capacity.seating_capacity)}</p>
        {typeof capacity.standing_capacity === 'number' ? <p><strong>立見等:</strong> {formatNumber(capacity.standing_capacity)}</p> : null}
        <p>{capacity.scale_note_ja ?? '収容人数は、より確実な資料を確認できた場合に更新します。'}</p>
        {capacity.source_url ? <p><a href={capacity.source_url}>収容人数の参照元</a></p> : null}
      </article>
    ) : null}

    <article class="card">
      <h2>開催予定</h2>
      {upcomingMeetings.length ? (
        <ul>
          {upcomingMeetings.map((meeting) => <li>{formatRecordFields(meeting, meetingFields)}</li>)}
        </ul>
      ) : (
        <p>このページでは、直近の開催予定はまだ表示していません。カレンダー側のデータ接続後、この欄に開催予定を表示します。</p>
      )}
      <p>{primaryScheduleUrl ? <a href={primaryScheduleUrl}>最新の開催予定を見る</a> : <a href={calendarHref}>カレンダーを見る</a>}</p>
    </article>
  </section>

  <section class="section-grid" aria-label="競馬種別とレース条件">
    <article class="card">
      <h2>競馬種別</h2>
      <ul>
        {track.racing_types.map((typeId) => {
          const type = getRacingTypeById(typeId);
          return <li>{type ? <a href={`/ja/types/${type.slug}/`}>{type.name_ja}</a> : typeId}</li>;
        })}
      </ul>
    </article>

    {upcomingConditions.length ? (
      <article class="card">
        <h2>直近開催のレース条件</h2>
        <ul>
          {upcomingConditions.map((condition) => <li>{formatRecordFields(condition, raceConditionFields)}</li>)}
        </ul>
      </article>
    ) : null}
  </section>

  <section class="section-grid" aria-label="コース構造と実施距離">
    <article class="card">
      <h2>コース構造</h2>
      {courseGroups.length ? (
        <div>
          {courseGroups.map(([label, rows]) => (
            <div>
              <h3>{label}</h3>
              <ul>
                {rows.map((course) => (
                  <li>
                    <strong>{course.label}</strong>
                    {' — '}{formatMeters(course.circumference_m)}
                    {course.direction ? ` ・ ${directionLabel(course.direction)}` : ''}
                    {course.surface ? ` ・ ${course.surface}` : ''}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <div>
          <p>{track.course_profile?.course_notes_ja ?? 'コース構造は今後追加します。'}</p>
          {fallbackCourseRows.length ? <ul>{fallbackCourseRows.map(([label, value]) => <li><strong>{label}:</strong> {formatMeters(value)}</li>)}</ul> : null}
        </div>
      )}
      <p>{courseLayout.inner_outer_note_ja ?? '詳細な仮柵設定やコース図は、コース詳細ページで確認できます。'}</p>
      {primaryCourseUrl ? <p><a href={primaryCourseUrl}>コース詳細を見る</a></p> : null}
    </article>

    {raceDistanceRows.length ? (
      <article class="card">
        <h2>実施レース距離</h2>
        <p>実施レース距離は、コース1周距離とは別の情報です。</p>
        {raceDistanceRows.map(([label, value]) => <p><strong>{label}:</strong> {value}</p>)}
      </article>
    ) : null}
  </section>

  <section class="section-grid" aria-label="代表レース・開催シーズン・リンク">
    <article class="card">
      <h2>代表レース</h2>
      {track.notable_races?.length ? (
        <ul>
          {track.notable_races.map((race) => {
            const row = toRecord(race);
            const name = row.name_ja ?? row.name ?? row.race_name;
            const url = row.source_url ?? row.official_link ?? row.url;
            return <li>{typeof url === 'string' ? <a href={url}>{name}</a> : name}</li>;
          })}
        </ul>
      ) : (
        <p>代表レースは今後追加します。</p>
      )}
      <p>格付け、距離、馬場、開催時期は、整理できたものから追加します。</p>
    </article>

    <article class="card">
      <h2>開催シーズン</h2>
      <p>{track.seasonality?.summary_ja ?? '開催シーズンは今後追加します。'}</p>
      <p><strong>状態:</strong> {statusLabel(track.seasonality?.status)}</p>
    </article>

    <article class="card">
      <h2>公式・来場関連リンク</h2>
      {linkRows.length ? (
        <ul>
          {linkRows.map(([label, url]) => <li><a href={url}>{label}</a></li>)}
        </ul>
      ) : (
        <p>リンクは今後追加します。</p>
      )}
    </article>
  </section>

  <section class="section-grid" aria-label="関連ページとデータ状態">
    <article class="card">
      <h2>関連学習</h2>
      <p><a href={countryHref}>国ページを開く</a></p>
      {relatedTerms.length ? (
        <ul>
          {relatedTerms.map((termId) => {
            const term = glossaryById.get(termId);
            return <li>{term ? <a href={`/ja/glossary/${term.slug}/`}>{term.term_ja}</a> : termId}</li>;
          })}
        </ul>
      ) : (
        <p>関連用語は今後追加します。</p>
      )}
    </article>

    <article class="card">
      <h2>関連ソース</h2>
      <p><a href={countrySourceHref}>国別ソース一覧を開く</a></p>
      {relatedSources.length ? (
        <ul>
          {relatedSources.map((sourceId) => {
            const source = sourcesById.get(sourceId);
            return <li>{source ? <a href={source.url}>{source.id}</a> : sourceId}</li>;
          })}
        </ul>
      ) : (
        <p>関連ソースは今後追加します。</p>
      )}
    </article>

    <article class="card">
      <h2>データ状態</h2>
      <p><strong>コース情報:</strong> {statusLabel(track.data_status?.course_profile)}</p>
      <p><strong>開催予定:</strong> {statusLabel(track.data_status?.schedule)}</p>
      <p><strong>収容人数:</strong> {statusLabel(capacity.status)}</p>
      <p><strong>実施距離:</strong> {statusLabel(raceDistanceProfile.status)}</p>
      <p><strong>最終確認:</strong> {formatValue(track.data_status?.last_checked)}</p>
      <p>Where Horses Run / 競馬どこ？ は、競馬場情報と開催予定への入口を整理するサイトです。出走表・オッズ・結果・払戻・予想・完全なレースカードは掲載しません。</p>
    </article>
  </section>

  <p><a href="/ja/tracks/">戻る</a></p>
</BaseLayout>
