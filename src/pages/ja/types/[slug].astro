---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  getRacecoursesByRacingTypeId,
  getRacingTypeBySlug,
  getRacingTypeGlossaryEntry,
  getRacingTypeRelatedGlossaryEntries,
  getRacingTypes
} from '../../../lib/racingTypes';
import { getCountries } from '../../../lib/data';

export function getStaticPaths() {
  return getRacingTypes().map((type) => ({ params: { slug: type.slug } }));
}

const { slug } = Astro.params;
const type = getRacingTypeBySlug(slug ?? '');

if (!type) {
  return Astro.redirect('/ja/types/');
}

const tracks = getRacecoursesByRacingTypeId(type.id);
const countries = getCountries();
const countryById = new Map(countries.map((country) => [country.id, country]));
const countryIds = [...new Set(tracks.map((track) => track.country_id))];
const glossaryEntry = getRacingTypeGlossaryEntry(type);
const relatedTerms = getRacingTypeRelatedGlossaryEntries(type);
const surfaces = [...new Set(tracks.flatMap((track) => track.surfaces ?? []))].sort();
---

<BaseLayout lang="ja" title={`${type.name_ja} | 競馬種別 | 競馬どこ？`} description={type.summary_ja}>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Racing type</p>
    <h1 id="page-title">{type.name_ja}</h1>
    <p class="hero__summary">{type.summary_ja}</p>
  </section>

  <section class="section-grid" aria-label="競馬種別詳細">
    <article class="card">
      <h2>概要</h2>
      <p>{type.summary_ja}</p>
      <p><strong>登録競馬場:</strong> {tracks.length}</p>
      <p><strong>関連国・地域:</strong> {countryIds.length}</p>
      <p><strong>馬場タグ:</strong> {surfaces.length ? surfaces.join(', ') : '未確認'}</p>
    </article>

    <article class="card">
      <h2>関連競馬場</h2>
      {tracks.length ? (
        <ul>
          {tracks.map((track) => (
            <li>
              <a href={`/ja/tracks/${track.slug}/`}>{track.name_ja}</a> — {track.city} / {countryById.get(track.country_id)?.name_ja ?? track.country_id}
              <br />
              <span>馬場: {track.surfaces.length ? track.surfaces.join(', ') : '未確認'} · 開催予定: {track.schedule_summary?.status ?? 'official-link-only'}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p>この競馬種別に紐づく競馬場はまだありません。</p>
      )}
    </article>

    <article class="card">
      <h2>関連国・地域</h2>
      {countryIds.length ? (
        <ul>
          {countryIds.map((countryId) => {
            const country = countryById.get(countryId);
            const count = tracks.filter((track) => track.country_id === countryId).length;
            return <li>{country ? <a href={`/ja/countries/${country.slug}/`}>{country.name_ja}</a> : countryId} — {count}件</li>;
          })}
        </ul>
      ) : (
        <p>関連国・地域はまだありません。</p>
      )}
    </article>

    <article class="card">
      <h2>関連用語</h2>
      {relatedTerms.length ? (
        <ul>
          {relatedTerms.map((term) => (
            <li><a href={`/ja/glossary/${term.slug}/`}>{term.term_ja}</a> — {term.summary_ja}</li>
          ))}
        </ul>
      ) : (
        <p>関連用語はまだありません。</p>
      )}
    </article>

    <article class="card">
      <h2>主な用語説明</h2>
      {glossaryEntry ? (
        <>
          <p>{glossaryEntry.summary_ja}</p>
          <p><a href={`/ja/glossary/${glossaryEntry.slug}/`}>用語ページを開く</a></p>
        </>
      ) : (
        <p>紐づく用語ページはまだありません。</p>
      )}
    </article>

    <article class="card">
      <h2>掲載範囲</h2>
      <p>出走表・オッズ・結果・払戻・予想・全文レースカードは、公式またはライセンスされたソースで確認してください。</p>
    </article>
  </section>

  <p><a href="/ja/types/">競馬種別一覧へ戻る</a></p>
</BaseLayout>
