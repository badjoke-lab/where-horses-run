---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  getCountries,
  getCountryBySlug,
  getRacecoursesByCountryId,
  getSourcesByCountryId,
  siteData
} from '../../../lib/data';

export function getStaticPaths() {
  return getCountries().map((country) => ({ params: { slug: country.slug } }));
}

const { slug } = Astro.params;
const country = getCountryBySlug(slug ?? '');

if (!country) {
  return Astro.redirect('/ja/countries/');
}

const racecourses = getRacecoursesByCountryId(country.id);
const sources = getSourcesByCountryId(country.id);
const fetchStatuses = siteData.generated.fetchStatus.sources ?? [];
const countryFetchStatuses = fetchStatuses.filter((status) => status.country_id === country.id);
const liveFetchProbes = siteData.generated.liveFetchProbeStatus?.probes ?? [];
const countryLiveFetchProbes = liveFetchProbes.filter((probe) => probe.country_id === country.id);
const alphaSources = sources.filter((source) => source.m3_status === 'alpha_link_first');
const hasAlphaCoverage = alphaSources.length > 0 || countryFetchStatuses.length > 0;
const timetableData = siteData.generated.timetables;
const timetableRecords = (timetableData.records ?? []).filter(
  (record) => (record.country_id ?? timetableData.country_id) === country.id
);
const hasTimetableFallback = timetableData.country_id === country.id;
const hasTimetableData = hasTimetableFallback || timetableRecords.length > 0;
const timetableSources = hasTimetableFallback
  ? (timetableData.sources ?? [])
      .map((sourceId) => sources.find((source) => source.id === sourceId) ?? { id: sourceId, url: '' })
  : [];
const timetableModeLabel = timetableData.mode.replace(/-/g, ' ');
---

<BaseLayout title={`${country.name_ja} | 競馬どこ？`} description={country.summary_ja} lang="ja">
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Country profile</p>
    <h1 id="page-title">{country.name_ja}</h1>
    <p class="hero__summary">{country.summary_ja}</p>
  </section>

  <section class="section-grid" aria-label="profile">
    <article class="card">
      <h2>Profile</h2>
      <p><strong>Region:</strong> {country.region}</p>
      <p><strong>Status:</strong> {country.status}</p>
      <p><strong>Coverage:</strong> Level {country.coverage_level} / Auto {country.auto_level}</p>
    </article>

    <article class="card">
      <h2>Racing types</h2>
      <p>{country.racing_types.join(', ')}</p>
    </article>

    <article class="card">
      <h2>公式ソース確認</h2>
      <p>開催詳細、出走表、オッズ、結果、払戻は公式または許諾済みソースで確認してください。</p>
    </article>
  </section>

  <section class="section-grid" aria-label="安全な開催時刻データ">
    <article class="card">
      <h2>安全な開催時刻データ</h2>
      <p><strong>country_id:</strong> {country.id}</p>
      {hasTimetableData ? (
        <>
          <p><strong>状態:</strong> {hasTimetableFallback ? timetableModeLabel : '確認済みレコードあり'}</p>
          <p><strong>Mode:</strong> {hasTimetableFallback ? timetableModeLabel : 'record data'}</p>
          <p><strong>確認済みレコード:</strong> {timetableRecords.length}</p>
          <p><strong>手動fallback:</strong> {hasTimetableFallback ? '手動fallback' : 'なし'}</p>
          <p><strong>last generated:</strong> {hasTimetableFallback ? timetableData.generated_at : 'この国では未掲載'}</p>
          <p><strong>live fetch:</strong> disabled</p>
          <p><strong>最終確認:</strong> 公式ソースリンクで最終確認してください。</p>
        </>
      ) : (
        <>
          <p><strong>状態:</strong> timetable recordsなし</p>
          <p><strong>確認済みレコード:</strong> 0</p>
          <p><strong>手動fallback:</strong> なし</p>
          <p><strong>live fetch:</strong> disabled</p>
          <p>この国の安全な開催時刻レコードはまだありません。</p>
          <p>最終確認には公式ソースリンクを使用してください。</p>
        </>
      )}
    </article>

    <article class="card">
      <h2>公式ソースとnotes</h2>
      {timetableSources.length > 0 ? (
        <>
          <p><strong>公式ソース:</strong></p>
          <ul>
            {timetableSources.map((source) => (
              <li>
                {source.url ? <a href={source.url}>{source.id}</a> : <span>{source.id}</span>}
              </li>
            ))}
          </ul>
        </>
      ) : (
        <p>この国のtimetable専用ソースリンクはまだありません。</p>
      )}
      {hasTimetableFallback && timetableData.notes.length > 0 ? (
        <>
          <p><strong>notes:</strong></p>
          <ul>
            {timetableData.notes.map((note) => <li>{note}</li>)}
          </ul>
        </>
      ) : (
        <p><strong>notes:</strong> 将来の確認済み開催日・発走時刻レコードを表示できる安全な構造です。</p>
      )}
    </article>

    <article class="card">
      <h2>確認済みtimetable records</h2>
      {timetableRecords.length > 0 ? (
        <ul>
          {timetableRecords.map((record) => (
            <li>
              <strong>{record.racecourse_name ?? record.racecourse_id ?? 'Racecourse pending'}</strong>
              <br />
              <span>date: {record.date ?? '未掲載'} / start_time_local: {record.start_time_local ?? '未掲載'} / timezone: {record.timezone ?? '未掲載'}</span>
              <br />
              <span>racing_type: {record.racing_type ?? '未掲載'}</span>
              <br />
              <span>source_url: {record.source_url ? <a href={record.source_url}>{record.source_id}</a> : record.source_id}</span>
              <br />
              <span>last_checked_at: {record.last_checked_at} / status: {record.status} / confidence: {record.confidence}</span>
              {record.notes && (
                <>
                  <br />
                  <span>notes: {Array.isArray(record.notes) ? record.notes.join('; ') : record.notes}</span>
                </>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <p>Records: 確認済みtimetable recordsはまだありません。</p>
      )}
    </article>
  </section>

  {hasAlphaCoverage && (
    <section class="section-grid" aria-label="alpha timetable coverage">
      <article class="card">
        <h2>Alpha timetable coverage</h2>
        <p><strong>Mode:</strong> link-first / dry-run</p>
        <p><strong>Live fetching:</strong> disabled</p>
        <p><strong>Current scope:</strong> 公式ソース案内、generated fallback表示、FetchStatus表示、UI確認。</p>
      </article>

      <article class="card">
        <h2>FetchStatus coverage</h2>
        {countryFetchStatuses.length > 0 ? (
          <ul>
            {countryFetchStatuses.map((status) => (
              <li>
                <strong>{status.source_id}</strong>: {status.status} — {status.message}
              </li>
            ))}
          </ul>
        ) : (
          <p>この国のFetchStatusはまだありません。</p>
        )}
      </article>

      <article class="card">
        <h2>Generated coverage fallback</h2>
        <p>この国では、まだlive timetableを取得していません。最終確認には公式ソースを使用してください。</p>
        <p>このページでは出走表、オッズ、結果、払戻、予想情報を再掲載しません。</p>
      </article>

      <article class="card">
        <h2>Live fetch probe status</h2>
        {countryLiveFetchProbes.length > 0 ? (
          <ul>
            {countryLiveFetchProbes.map((probe) => (
              <li>
                <strong>{probe.source_id}</strong>: {probe.status} / HTTP {probe.http_status}
                <br />
                <span>Checked: {probe.checked_at}</span>
                <br />
                <span>Final URL: {probe.final_url}</span>
                <br />
                <span>Content type: {probe.content_type}</span>
                <br />
                <span>Safety: raw_content_saved={String(probe.raw_content_saved)}, body_read={String(probe.body_read)}, generated_files_written={String(probe.generated_files_written)}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p>この国のlive fetch probeメタデータはまだありません。</p>
        )}
      </article>
    </section>
  )}

  <section class="section-grid" aria-label="racecourses and sources">
    <article class="card">
      <h2>Racecourses</h2>
      {racecourses.length > 0 ? (
        <ul>
          {racecourses.map((racecourse) => <li>{racecourse.name_ja} — {racecourse.city}</li>)}
        </ul>
      ) : (
        <p>競馬場データはまだありません。</p>
      )}
    </article>

    <article class="card">
      <h2>Official sources</h2>
      {sources.length > 0 ? (
        <ul>
          {sources.map((source) => (
            <li>
              <a href={source.url}>{source.id}</a>
              <br />
              <span>{source.data_type} / Auto {source.auto_level}</span>
              <br />
              <span>{source.notes}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p>公式ソースデータはまだありません。</p>
      )}
    </article>
  </section>

  <p><a href="/ja/countries/">Back</a></p>
</BaseLayout>
