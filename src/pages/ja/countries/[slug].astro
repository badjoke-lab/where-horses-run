---
import CountryDetailPage from '../../../components/CountryDetailPage.astro';
import { getCountries, getCountryBySlug } from '../../../lib/data';

export function getStaticPaths() {
  return getCountries().map((country) => ({ params: { slug: country.slug } }));
}

const { slug } = Astro.params;
const country = getCountryBySlug(slug ?? '');

if (!country) {
  return Astro.redirect('/ja/countries/');
}
---

<CountryDetailPage country={country} locale="ja" />
