---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimetableMeetingList from '../../components/TimetableMeetingList.astro';
import { getTimetableMeetingRowsForDate, getTomorrowTimetableDate } from '../../data/timetableMeetingRows';

const tomorrowTimetableDate = getTomorrowTimetableDate();
const tomorrowRecords = getTimetableMeetingRowsForDate(tomorrowTimetableDate);
---

<BaseLayout
  title="明日の開催時刻表 | 競馬どこ？"
  description="明日の開催一覧を1開催1行で表示し、利用可能な時刻情報、詳細ページ、公式ソースを案内します。"
  lang="ja"
  canonicalPath="/ja/tomorrow/"
  alternatePath="/tomorrow/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Tomorrow</p>
    <h1 id="page-title">明日の開催時刻表</h1>
    <p class="hero__summary">
      {tomorrowTimetableDate} の開催情報です。表示ランクに応じて時刻情報を出し分けます。
    </p>
  </section>

  <section aria-label="明日の開催一覧">
    <TimetableMeetingList
      records={tomorrowRecords}
      date={tomorrowTimetableDate}
      lang="ja"
      emptyLabel="明日の開催情報はまだありません。最終確認には公式ソースを使用してください。"
    />
  </section>
</BaseLayout>
