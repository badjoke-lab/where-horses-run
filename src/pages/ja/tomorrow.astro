---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalendarDateStatus from '../../components/CalendarDateStatus.astro';
import TimetableMeetingList from '../../components/TimetableMeetingList.astro';
import { getTimetableDataState, getTimetableDateContext, getTimetableMeetingRowsForDate } from '../../data/timetableMeetingRows';

const context = getTimetableDateContext();
const dataState = getTimetableDataState(context);
const tomorrowRecords = getTimetableMeetingRowsForDate(context.tomorrow);
---

<BaseLayout
  title="明日の開催時刻表 | 競馬どこ？"
  description="明日の開催一覧を1開催1行で表示し、利用可能な時刻情報、詳細ページ、公式ソースを案内します。"
  lang="ja"
  canonicalPath="/ja/tomorrow/"
  alternatePath="/tomorrow/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Tomorrow</p>
    <h1 id="page-title">明日の開催時刻表</h1>
    <p class="hero__summary">
      {context.tomorrow} の開催情報です。表示ランクに応じて時刻情報を出し分けます。
    </p>
  </section>

  <CalendarDateStatus context={context} dataState={dataState} lang="ja" />

  <section aria-label="明日の開催一覧">
    <TimetableMeetingList
      records={tomorrowRecords}
      date={context.tomorrow}
      lang="ja"
      emptyLabel="明日の確認済み公開開催はありません。最新情報は公式ソースで確認してください。"
    />
  </section>
</BaseLayout>
