---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Where Horses Run | Global Horse Racing Calendar & Timetable"
  description="Find horse racing days, race times, racecourses, and official source links around the world."
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Global Horse Racing Calendar & Timetable</p>
    <h1 id="page-title">Where Horses Run</h1>
    <p class="hero__summary">
      A static-first guide for finding racing days, race times, racecourses, official source links, and glossary context across racing jurisdictions.
    </p>
  </section>

  <section class="section-grid" aria-label="Initial project scope">
    <article class="card">
      <h2>Find racing days</h2>
      <p>Start from country and racecourse pages, then move to official calendars and timetable sources.</p>
    </article>
    <article class="card">
      <h2>Use official details</h2>
      <p>Race details, entries, odds, results, and payouts belong on official or licensed source pages.</p>
    </article>
    <article class="card">
      <h2>Understand the terms</h2>
      <p>The glossary will explain racing types, roles, timetable words, and official-site terminology.</p>
    </article>
  </section>
</BaseLayout>
