---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Where Horses Run | Global Horse Racing Calendar & Timetable"
  description="Find horse racing days, race times, racecourses, and official source links around the world."
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Global Horse Racing Calendar & Timetable</p>
    <h1 id="page-title">Where Horses Run</h1>
    <p class="hero__summary">
      A static-first guide for finding racing days, race times, racecourses, official source links, and glossary context across racing jurisdictions.
    </p>
  </section>

  <section class="section-grid" aria-label="Main navigation cards">
    <article class="card">
      <h2><a href="/today/">Today</a></h2>
      <p>Safe timetable records listed for today, with clear empty states when none are verified.</p>
    </article>

    <article class="card">
      <h2><a href="/calendar/">Calendar</a></h2>
      <p>Fallback calendar pages and generated schedule status.</p>
    </article>

    <article class="card">
      <h2><a href="/countries/">Countries</a></h2>
      <p>Browse racing jurisdictions and country coverage notes.</p>
    </article>

    <article class="card">
      <h2><a href="/tracks/">Tracks</a></h2>
      <p>Browse racecourse entries and racing type summaries.</p>
    </article>

    <article class="card">
      <h2><a href="/glossary/">Glossary</a></h2>
      <p>Understand timetable and racing terminology.</p>
    </article>

    <article class="card">
      <h2><a href="/sources/">Sources</a></h2>
      <p>Browse official and reference source links.</p>
    </article>

    <article class="card">
      <h2><a href="/about/">About</a></h2>
      <p>Project scope, disclaimer, and coverage notes.</p>
    </article>
  </section>
</BaseLayout>
