---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteData, getCountries } from '../../lib/data';

const sources = siteData.sources;
const countries = getCountries();
const countryById = new Map(countries.map((country) => [country.id, country]));
const sourceGroups = countries
  .map((country) => ({
    country,
    sources: sources.filter((source) => source.country_id === country.id)
  }))
  .filter((group) => group.sources.length > 0);
---

<BaseLayout
  title="Sources | Where Horses Run"
  description="Browse official and reference source links used by Where Horses Run."
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Sources</p>
    <h1 id="page-title">Sources</h1>
    <p class="hero__summary">
      Browse source entries used for country and racing coverage notes.
    </p>
  </section>

  <section class="section-grid" aria-label="Source groups">
    <article class="card">
      <h2>Browse by country</h2>
      <ul>
        {sourceGroups.map(({ country, sources }) => (
          <li><a href={`/sources/${country.slug}/`}>{country.name_en}</a> — {sources.length} source{sources.length === 1 ? '' : 's'}</li>
        ))}
      </ul>
    </article>
  </section>

  <section class="section-grid" aria-label="Source list">
    {sources.map((source) => {
      const country = countryById.get(source.country_id);
      return (
        <article class="card">
          <h2><a href={source.url}>{source.id}</a></h2>
          <p>{country ? <a href={`/sources/${country.slug}/`}>{country.name_en}</a> : source.country_id}</p>
          <p><strong>Type:</strong> {source.source_type}</p>
          <p><strong>Data:</strong> {source.data_type}</p>
          <p><strong>Auto:</strong> {source.auto_level}</p>
        </article>
      );
    })}
  </section>
</BaseLayout>
