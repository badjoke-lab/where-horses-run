---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Legacy Timetable Preview Retired | Where Horses Run"
  description="The former normalized-sample timetable preview has been retired. Use the reviewed public Calendar, Today, and Tomorrow views instead."
  canonicalPath="/major-countries/preview-timetable/"
>
  <nav class="retired-preview__nav" aria-label="Timetable navigation">
    <a href="/calendar/">Calendar</a>
    <a href="/today/">Today</a>
    <a href="/tomorrow/">Tomorrow</a>
    <a href="/major-countries/current-timetable/">Current timetable</a>
  </nav>

  <section class="retired-preview card" aria-labelledby="page-title">
    <p class="retired-preview__eyebrow">Legacy preview retired</p>
    <h1 id="page-title">Major Country Timetable Preview</h1>
    <p>
      This route previously displayed development-era normalized samples. Those samples are no longer a public timetable source and are not rendered here.
    </p>
    <p>
      Where Horses Run now reads reviewed public timetable projections generated from canonical meeting data, publication policy, and Calendar Readiness.
    </p>
    <p>
      Use the current Calendar, Today, Tomorrow, country, racecourse, and meeting-detail pages for public timetable information.
    </p>
  </section>

  <section class="retired-preview__boundary card" aria-labelledby="boundary-title">
    <h2 id="boundary-title">Publication boundary</h2>
    <p>
      Preview fixtures, normalized samples, candidates, source snapshots, and legacy integrated data are not public runtime inputs.
    </p>
    <p>
      Complete official information should be confirmed at the linked official source.
    </p>
  </section>
</BaseLayout>

<style>
  .retired-preview__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-block-end: 2rem;
  }

  .retired-preview,
  .retired-preview__boundary {
    display: grid;
    gap: 0.9rem;
  }

  .retired-preview__boundary {
    margin-block-start: 1.5rem;
  }

  .retired-preview__eyebrow,
  .retired-preview h1,
  .retired-preview h2,
  .retired-preview p,
  .retired-preview__boundary h2,
  .retired-preview__boundary p {
    margin: 0;
  }

  .retired-preview__eyebrow {
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
