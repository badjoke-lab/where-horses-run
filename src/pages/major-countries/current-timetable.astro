---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CurrentTimetableRecords from '../../components/CurrentTimetableRecords.astro';
import CurrentTimetableDimensions from '../../components/CurrentTimetableDimensions.astro';
import currentTimetable from '../../../data/generated/timetable/real-calendar-all-countries.json';

const records = currentTimetable.records;

function countBy(records, field) {
  const counts = new Map();
  for (const record of records) {
    const label = record[field];
    counts.set(label, (counts.get(label) ?? 0) + 1);
  }
  return [...counts.entries()]
    .map(([label, count]) => ({ label, count }))
    .sort((a, b) => a.label.localeCompare(b.label));
}

const countries = countBy(records, 'country_label');
const groups = countBy(records, 'group_label');
const dates = countBy(records, 'meeting_date');
const racecourses = countBy(records, 'racecourse');
---

<BaseLayout
  title="Current Timetable | Where Horses Run"
  description="Display-ready real-source timetable records with race times, source trace, and last checked fields."
  canonicalPath="/major-countries/current-timetable/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Current timetable</p>
    <h1 id="page-title">Current real-source timetable</h1>
    <div class="hero__summary">
      <p>This page shows the real-source timetable records for the 13-country v0 scope.</p>
      <p>It includes country, system, date, racecourse, first race time when available, all race times when available, source trace, and last checked fields.</p>
    </div>
  </section>

  <section class="section-grid" aria-label="Current timetable summary">
    <article class="card">
      <h2>Records</h2>
      <p><strong>Current records:</strong> {records.length}</p>
    </article>
    <article class="card">
      <h2>Countries</h2>
      <p>{countries.map((item) => item.label).join(', ')}</p>
    </article>
    <article class="card">
      <h2>Systems</h2>
      <p>{groups.map((item) => item.label).join(', ')}</p>
    </article>
    <article class="card">
      <h2>Dates</h2>
      <p>{dates.map((item) => item.label).join(', ')}</p>
    </article>
    <article class="card">
      <h2>Racecourses</h2>
      <p>{racecourses.map((item) => item.label).join(', ')}</p>
    </article>
  </section>

  <CurrentTimetableDimensions countries={countries} groups={groups} dates={dates} racecourses={racecourses} />
  <CurrentTimetableRecords records={records} />
</BaseLayout>
