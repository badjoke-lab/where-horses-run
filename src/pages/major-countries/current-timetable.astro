---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CurrentTimetableRecords from '../../components/CurrentTimetableRecords.astro';
import currentTimetable from '../../../data/generated/timetable/current-integrated.json';

const records = currentTimetable.records;
const countries = [...new Set(records.map((record) => record.country_label))].sort();
const groups = [...new Set(records.map((record) => record.group_label))].sort();
const dates = [...new Set(records.map((record) => record.meeting_date))].sort();
const racecourses = [...new Set(records.map((record) => record.racecourse))].sort();
---

<BaseLayout
  title="Current Timetable | Where Horses Run"
  description="Display-ready current timetable records with race times, source trace, and last checked fields."
  canonicalPath="/major-countries/current-timetable/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Current timetable</p>
    <h1 id="page-title">Current integrated timetable</h1>
    <div class="hero__summary">
      <p>This page shows the generated integrated timetable records prepared for display.</p>
      <p>It includes country, system, date, racecourse, first race time, all race times, source trace, and last checked fields.</p>
    </div>
  </section>

  <section class="section-grid" aria-label="Current timetable summary">
    <article class="card">
      <h2>Records</h2>
      <p><strong>Current records:</strong> {records.length}</p>
    </article>
    <article class="card">
      <h2>Countries</h2>
      <p>{countries.join(', ')}</p>
    </article>
    <article class="card">
      <h2>Systems</h2>
      <p>{groups.join(', ')}</p>
    </article>
    <article class="card">
      <h2>Dates</h2>
      <p>{dates.join(', ')}</p>
    </article>
    <article class="card">
      <h2>Racecourses</h2>
      <p>{racecourses.join(', ')}</p>
    </article>
  </section>

  <CurrentTimetableRecords records={records} />
</BaseLayout>
