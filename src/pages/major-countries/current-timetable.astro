---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimetableMeetingList from '../../components/TimetableMeetingList.astro';
import { getGroupedTimetableMeetingRows } from '../../data/timetableMeetingRows';

const groupedTimetableRecords = getGroupedTimetableMeetingRows();
---

<BaseLayout
  title="June 2026 Timetable | Where Horses Run"
  description="A simple date-first June 2026 meeting list, with one official source link per meeting and race timetable links only where race-by-race times are available."
  canonicalPath="/major-countries/current-timetable/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Current timetable</p>
    <h1 id="page-title">June 2026 timetable</h1>
    <p class="hero__summary">
      Meetings grouped by date. Rank controls how much timing detail is shown.
    </p>
  </section>

  <section aria-label="June 2026 current timetable by date">
    <TimetableMeetingList
      groups={groupedTimetableRecords}
      emptyLabel="No June 2026 timetable meetings are listed yet. Use official source links for final confirmation."
    />
  </section>
</BaseLayout>
