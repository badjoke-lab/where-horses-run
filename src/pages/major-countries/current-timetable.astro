---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CurrentTimetableRecords from '../../components/CurrentTimetableRecords.astro';
import CurrentTimetableDimensions from '../../components/CurrentTimetableDimensions.astro';
import currentTimetable from '../../../data/generated/timetable/june-2026-calendar.json';
import manualCanadaStandardbred from '../../../data/generated/timetable/manual-june-2026-standardbred-canada.json';
import manualCanadaWoodbine from '../../../data/generated/timetable/manual-june-2026-woodbine-thoroughbred.json';
import manualNzLoveracing from '../../../data/generated/timetable/manual-june-2026-loveracing-thoroughbred.json';
import manualQueensland from '../../../data/generated/timetable/manual-june-2026-racing-queensland-thoroughbred.json';
import manualRacingNsw from '../../../data/generated/timetable/manual-june-2026-racing-nsw-thoroughbred.json';
import manualSouthAfrica from '../../../data/generated/timetable/manual-june-2026-gold-circle.json';
import manualUkArabian from '../../../data/generated/timetable/manual-june-2026-uk-purebred-arabian.json';
import manualUkPointToPoint from '../../../data/generated/timetable/manual-june-2026-uk-point-to-point.json';

const manualRecordSets = [
  manualCanadaStandardbred.record_set,
  manualCanadaWoodbine.record_set,
  manualNzLoveracing.record_set,
  manualQueensland.record_set,
  manualRacingNsw.record_set,
  manualSouthAfrica.record_set,
  manualUkArabian.record_set,
  manualUkPointToPoint.record_set
].filter(Boolean);

function slug(value) {
  return String(value).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

function cloneSet(set) {
  return {
    ...set,
    meetings: [...(set.meetings ?? [])]
  };
}

function mergeManualRecordSets(data) {
  const byGroup = new Map((data.record_sets ?? []).map((set) => [`${set.country_id}::${set.group_id}`, cloneSet(set)]));

  for (const manual of manualRecordSets) {
    const key = `${manual.country_id}::${manual.group_id}`;
    if (!byGroup.has(key)) byGroup.set(key, { ...manual, meetings: [] });
    const target = byGroup.get(key);
    target.source_trace = manual.source_trace;
    target.data_level = manual.data_level;
    for (const meeting of manual.meetings ?? []) {
      const meetingKey = `${meeting[0]}::${meeting[1]}`;
      const exists = target.meetings.some((item) => `${item[0]}::${item[1]}` === meetingKey);
      if (!exists) target.meetings.push(meeting);
    }
  }

  return [...byGroup.values()].map((set) => ({
    ...set,
    meetings: set.meetings.sort((a, b) => a[0].localeCompare(b[0]) || a[1].localeCompare(b[1]))
  })).sort((a, b) => `${a.country_id}::${a.group_id}`.localeCompare(`${b.country_id}::${b.group_id}`));
}

function expandRecordSets(recordSets) {
  return recordSets.flatMap((set) =>
    set.meetings.map(([meetingDate, racecourse]) => ({
      record_id: `june-2026-${set.country_id}-${set.group_id}-${meetingDate}-${slug(racecourse)}`,
      country_id: set.country_id,
      country_label: set.country_label,
      group_id: set.group_id,
      group_label: set.group_label,
      racecourse,
      meeting_date: meetingDate,
      data_level: set.data_level,
      data_origin: 'real_source',
      first_race_time: null,
      all_race_times: [],
      source_trace: set.source_trace,
      freshness: {
        status: 'real_source_checked',
        basis: 'official_month_calendar',
        source_capture_date: set.source_trace.source_capture_date,
        last_checked: set.source_trace.last_checked
      }
    }))
  );
}

const mergedRecordSets = mergeManualRecordSets(currentTimetable);
const records = Array.isArray(currentTimetable.records) ? currentTimetable.records : expandRecordSets(mergedRecordSets);
const coverage_status = currentTimetable.coverage_status ?? [];

function countBy(records, field) {
  const counts = new Map();
  for (const record of records) {
    const label = record[field];
    counts.set(label, (counts.get(label) ?? 0) + 1);
  }
  return [...counts.entries()]
    .map(([label, count]) => ({ label, count }))
    .sort((a, b) => a.label.localeCompare(b.label));
}

const countries = countBy(records, 'country_label');
const groups = countBy(records, 'group_label');
const dates = countBy(records, 'meeting_date');
const racecourses = countBy(records, 'racecourse');
---

<BaseLayout
  title="June 2026 Timetable | Where Horses Run"
  description="June 2026 real-source timetable records with racecourse, date, source trace, and last checked fields."
  canonicalPath="/major-countries/current-timetable/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Current timetable</p>
    <h1 id="page-title">June 2026 real-source timetable</h1>
    <div class="hero__summary">
      <p>This page shows June 2026 real-source timetable records currently connected to the calendar view.</p>
      <p>It includes country, system, date, racecourse, first race time when available, all race times when available, source trace, and last checked fields.</p>
    </div>
  </section>

  <section class="section-grid" aria-label="Current timetable summary">
    <article class="card">
      <h2>Records</h2>
      <p><strong>Current records:</strong> {records.length}</p>
    </article>
    <article class="card">
      <h2>Countries</h2>
      <p>{countries.map((item) => item.label).join(', ')}</p>
    </article>
    <article class="card">
      <h2>Systems</h2>
      <p>{groups.map((item) => item.label).join(', ')}</p>
    </article>
    <article class="card">
      <h2>Dates</h2>
      <p>{dates.map((item) => item.label).join(', ')}</p>
    </article>
    <article class="card">
      <h2>Racecourses</h2>
      <p>{racecourses.map((item) => item.label).join(', ')}</p>
    </article>
  </section>

  {coverage_status.length > 0 && (
    <section aria-labelledby="coverage-status-title">
      <h2 id="coverage-status-title">June coverage status</h2>
      <div class="section-grid">
        {coverage_status.map((item) => (
          <article class="card">
            <h3>{item.country_label} / {item.group_label}</h3>
            <p><strong>Status:</strong> {item.status}</p>
            <p>{item.reason}</p>
            <p><strong>Last checked:</strong> {item.source_trace.last_checked}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <CurrentTimetableDimensions countries={countries} groups={groups} dates={dates} racecourses={racecourses} />
  <CurrentTimetableRecords records={records} />
</BaseLayout>
