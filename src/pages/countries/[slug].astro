---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getCountries,
  getCountryBySlug,
  getRacecoursesByCountryId,
  getSourcesByCountryId,
  siteData
} from '../../lib/data';

export function getStaticPaths() {
  return getCountries().map((country) => ({
    params: { slug: country.slug }
  }));
}

const { slug } = Astro.params;
const country = getCountryBySlug(slug ?? '');

if (!country) {
  return Astro.redirect('/countries/');
}

const racecourses = getRacecoursesByCountryId(country.id);
const sources = getSourcesByCountryId(country.id);
const fetchStatuses = siteData.generated.fetchStatus.sources ?? [];
const countryFetchStatuses = fetchStatuses.filter((status) => status.country_id === country.id);
const liveFetchProbes = siteData.generated.liveFetchProbeStatus?.probes ?? [];
const countryLiveFetchProbes = liveFetchProbes.filter((probe) => probe.country_id === country.id);
const alphaSources = sources.filter((source) => source.m3_status === 'alpha_link_first');
const hasAlphaCoverage = alphaSources.length > 0 || countryFetchStatuses.length > 0;
const timetableData = siteData.generated.timetables;
const timetableRecords = (timetableData.records ?? []).filter(
  (record) => (record.country_id ?? timetableData.country_id) === country.id
);
const timetableSourceIds = new Set(timetableData.sources ?? []);
const countryTimetableSources = sources.filter((source) => timetableSourceIds.has(source.id));
const hasLegacyCountryFallback = timetableData.country_id === country.id;
const hasCountryTimetableSource = countryTimetableSources.length > 0;
const hasTimetableFallback = hasLegacyCountryFallback || hasCountryTimetableSource;
const hasTimetableData = hasTimetableFallback || timetableRecords.length > 0;
const timetableSources = countryTimetableSources;
const timetableModeLabel = timetableData.mode.replace(/-/g, ' ');
const racingInventory = siteData.countryRacingInventory;
const countryInventory = racingInventory.countries.find((entry) => entry.country_id === country.id);
const generatedDate = String(timetableData.generated_at ?? '').slice(0, 10);
const windowStart = generatedDate ? new Date(`${generatedDate}T00:00:00.000Z`) : null;
const windowEnd = windowStart
  ? new Date(Date.UTC(windowStart.getUTCFullYear(), windowStart.getUTCMonth(), windowStart.getUTCDate() + 30))
  : null;
const activeWindowRecords = windowStart && windowEnd
  ? timetableRecords.filter((record) => {
      const recordDate = new Date(`${record.date}T00:00:00.000Z`);
      return recordDate >= windowStart && recordDate < windowEnd;
    })
  : [];
const outOfWindowRecords = timetableRecords.length - activeWindowRecords.length;
---

<BaseLayout
  title={`${country.name_en} | Countries | Where Horses Run`}
  description={country.summary_en}
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Country profile</p>
    <h1 id="page-title">{country.name_en}</h1>
    <p class="hero__summary">{country.summary_en}</p>
  </section>

  <section class="section-grid" aria-label="Country details">
    <article class="card">
      <h2>Coverage</h2>
      <p><strong>Status:</strong> {country.status}</p>
      <p><strong>Region:</strong> {country.region}</p>
      <p><strong>Coverage level:</strong> {country.coverage_level}</p>
      <p><strong>Auto level:</strong> {country.auto_level}</p>
    </article>

    <article class="card">
      <h2>Racing types</h2>
      <p>{country.racing_types.join(', ')}</p>
    </article>

    <article class="card">
      <h2>Official-source boundary</h2>
      <p>Race details, entries, odds, results, and payouts should be confirmed on official or licensed source pages.</p>
    </article>
  </section>

  <section class="section-grid" aria-label="Country racing inventory and seed audit">
    <article class="card">
      <h2>Racing inventory status</h2>
      {countryInventory ? (
        <>
          <p><strong>Overall coverage status:</strong> {countryInventory.overall_coverage_status}</p>
          <p><strong>Current seed state:</strong> {countryInventory.current_seed_state}</p>
          <p><strong>Active 30-day records:</strong> {activeWindowRecords.length}</p>
          <p><strong>Out-of-window records:</strong> {outOfWindowRecords}</p>
          <p><strong>Rule:</strong> Initial seed and out-of-window seed data must not be treated as country coverage.</p>
        </>
      ) : (
        <p>No racing inventory entry exists for this country yet. It must not be treated as covered.</p>
      )}
    </article>

    <article class="card">
      <h2>Racing systems</h2>
      {countryInventory ? (
        <ul>
          {countryInventory.racing_systems.map((system) => (
            <li>
              <strong>{system.name}</strong> ({system.system_id})
              <br />
              <span>Status: {system.coverage_status}</span>
              <br />
              <span>Racecourses listed: {system.racecourses.length}</span>
              <br />
              <span>{system.coverage_notes}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p>No racing systems have been inventoried.</p>
      )}
    </article>

    <article class="card">
      <h2>Inventory racecourses and sources</h2>
      {countryInventory ? (
        <ul>
          {countryInventory.racing_systems.map((system) => (
            <li>
              <strong>{system.name}</strong>
              <br />
              <span>Official source candidates: {system.official_sources.map((source) => source.label).join(', ')}</span>
              <br />
              <span>Racecourses: {system.racecourses.length > 0 ? system.racecourses.map((racecourse) => racecourse.name).join(', ') : 'not inventoried yet'}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p>No inventory sources are listed.</p>
      )}
    </article>

    <article class="card">
      <h2>Do not claim</h2>
      {countryInventory ? (
        <ul>
          {countryInventory.must_not_claim.map((claim) => <li>{claim}</li>)}
        </ul>
      ) : (
        <p>This country must not be claimed as covered until inventory and coverage checks are added.</p>
      )}
    </article>
  </section>

  <section class="section-grid" aria-label="Safe timetable data">
    <article class="card">
      <h2>Safe timetable data</h2>
      <p><strong>Country ID:</strong> {country.id}</p>
      {hasTimetableData ? (
        <>
          <p><strong>Timetable status:</strong> {hasTimetableFallback ? timetableModeLabel : 'verified records listed'}</p>
          <p><strong>Mode:</strong> {hasTimetableFallback ? timetableModeLabel : 'record data'}</p>
          <p><strong>Verified records:</strong> {timetableRecords.length}</p>
          <p><strong>Active 30-day records:</strong> {activeWindowRecords.length}</p>
          <p><strong>Fallback/manual status:</strong> {hasTimetableFallback ? 'manual fallback' : 'none listed'}</p>
          <p><strong>Last generated:</strong> {hasTimetableFallback ? timetableData.generated_at : 'not listed for this country'}</p>
          <p><strong>Live fetching:</strong> disabled</p>
          <p><strong>Final confirmation:</strong> Use official source links for final confirmation.</p>
        </>
      ) : (
        <>
          <p><strong>Timetable status:</strong> no timetable records yet</p>
          <p><strong>Verified records:</strong> 0</p>
          <p><strong>Fallback/manual status:</strong> none listed</p>
          <p><strong>Live fetching:</strong> disabled</p>
          <p>No safe timetable records are listed for this country yet.</p>
          <p>Use official source links for final confirmation.</p>
        </>
      )}
    </article>

    <article class="card">
      <h2>Timetable sources and notes</h2>
      {timetableSources.length > 0 ? (
        <>
          <p><strong>Official source:</strong></p>
          <ul>
            {timetableSources.map((source) => (
              <li>
                {source.url ? <a href={source.url}>{source.id}</a> : <span>{source.id}</span>}
              </li>
            ))}
          </ul>
        </>
      ) : (
        <p>No timetable-specific source links are listed for this country yet.</p>
      )}
      {hasTimetableFallback && timetableData.notes.length > 0 ? (
        <>
          <p><strong>Notes:</strong></p>
          <ul>
            {timetableData.notes.map((note) => <li>{note}</li>)}
          </ul>
        </>
      ) : (
        <p><strong>Notes:</strong> Safe timetable display is ready for future verified date and start-time records.</p>
      )}
    </article>

    <article class="card">
      <h2>Verified timetable records</h2>
      {timetableRecords.length > 0 ? (
        <ul>
          {timetableRecords.map((record) => (
            <li>
              <strong>{record.racecourse_name ?? record.racecourse_id ?? 'Racecourse pending'}</strong>
              <br />
              <span>Date: {record.date ?? 'not listed'} / Start time: {record.start_time_local ?? 'not listed'} / Timezone: {record.timezone ?? 'not listed'}</span>
              <br />
              <span>Racing type: {record.racing_type ?? 'not listed'}</span>
              <br />
              <span>Source: {record.source_url ? <a href={record.source_url}>{record.source_id}</a> : record.source_id}</span>
              <br />
              <span>Last checked: {record.last_checked_at} / Status: {record.status} / Confidence: {record.confidence}</span>
              {record.notes && (
                <>
                  <br />
                  <span>Notes: {Array.isArray(record.notes) ? record.notes.join('; ') : record.notes}</span>
                </>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <p>Records: no verified timetable records yet.</p>
      )}
    </article>
  </section>

  {hasAlphaCoverage && (
    <section class="section-grid" aria-label="Alpha timetable coverage">
      <article class="card">
        <h2>Alpha timetable coverage</h2>
        <p><strong>Mode:</strong> link-first / dry-run</p>
        <p><strong>Live fetching:</strong> disabled</p>
        <p><strong>Current scope:</strong> official source routing, generated fallback visibility, FetchStatus display, and UI verification.</p>
      </article>

      <article class="card">
        <h2>FetchStatus coverage</h2>
        {countryFetchStatuses.length > 0 ? (
          <ul>
            {countryFetchStatuses.map((status) => (
              <li>
                <strong>{status.source_id}</strong>: {status.status} — {status.message}
              </li>
            ))}
          </ul>
        ) : (
          <p>No FetchStatus entry is listed for this country yet.</p>
        )}
      </article>

      <article class="card">
        <h2>Generated coverage fallback</h2>
        <p>No live timetable has been fetched for this country yet. Use official source links for confirmation.</p>
        <p>This page does not republish racecards, entries, odds, results, payouts, or betting tips.</p>
      </article>

      <article class="card">
        <h2>Live fetch probe status</h2>
        {countryLiveFetchProbes.length > 0 ? (
          <ul>
            {countryLiveFetchProbes.map((probe) => (
              <li>
                <strong>{probe.source_id}</strong>: {probe.status} / HTTP {probe.http_status}
                <br />
                <span>Checked: {probe.checked_at}</span>
                <br />
                <span>Final URL: {probe.final_url}</span>
                <br />
                <span>Content type: {probe.content_type}</span>
                <br />
                <span>Safety: raw_content_saved={String(probe.raw_content_saved)}, body_read={String(probe.body_read)}, generated_files_written={String(probe.generated_files_written)}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p>No live fetch probe metadata is listed for this country yet.</p>
        )}
      </article>
    </section>
  )}

  <section class="section-grid" aria-label="Racecourses and sources">
    <article class="card">
      <h2>Racecourses</h2>
      {racecourses.length > 0 ? (
        <ul>
          {racecourses.map((racecourse) => <li>{racecourse.name_en} — {racecourse.city}</li>)}
        </ul>
      ) : (
        <p>No racecourse entries are listed yet.</p>
      )}
    </article>

    <article class="card">
      <h2>Official sources</h2>
      {sources.length > 0 ? (
        <ul>
          {sources.map((source) => (
            <li>
              <a href={source.url}>{source.id}</a>
              <br />
              <span>{source.data_type} / Auto {source.auto_level}</span>
              <br />
              <span>{source.notes}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p>No source entries are listed yet.</p>
      )}
    </article>
  </section>

  <p><a href="/countries/">Back to countries</a></p>
</BaseLayout>
