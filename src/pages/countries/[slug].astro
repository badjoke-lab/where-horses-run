---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContextTimetableTable from '../../components/ContextTimetableTable.astro';
import {
  getCountries,
  getCountryBySlug,
  getCountryProfileByCountryId,
  getRacecoursesByCountryId,
  getSourcesByCountryId,
  siteData
} from '../../lib/data';
import { getTimetableMeetingRowsByCountry } from '../../data/timetableMeetingRows';

export function getStaticPaths() {
  return getCountries().map((country) => ({ params: { slug: country.slug } }));
}

const { slug } = Astro.params;
const country = getCountryBySlug(slug ?? '');
if (!country) return Astro.redirect('/countries/');

const profile = getCountryProfileByCountryId(country.id);
const racecourses = getRacecoursesByCountryId(country.id);
const sources = getSourcesByCountryId(country.id);
const sourcesById = new Map(sources.map((source) => [source.id, source]));
const publicMeetings = getTimetableMeetingRowsByCountry(country.id);
const racingInventory = siteData.countryRacingInventory;
const countryInventory = racingInventory.countries.find((entry) => entry.country_id === country.id);
const fetchStatuses = siteData.generated.fetchStatus.sources ?? [];
const countryFetchStatuses = fetchStatuses.filter((status) => status.country_id === country.id);
const liveFetchProbes = siteData.generated.liveFetchProbeStatus?.probes ?? [];
const countryLiveFetchProbes = liveFetchProbes.filter((probe) => probe.country_id === country.id);

const sourceLabelById: Record<string, string> = {
  'japan-jra-home': 'JRA official site',
  'japan-jairs-racecourses': 'JAIRS / JRA racecourse guide',
  'japan-nar-home': 'Local Government Racing official site',
  'japan-nar-racecourse-guide': 'NAR racecourse guide',
  'japan-banei-home': 'Banei Tokachi official site',
  'japan-banei-monthly-schedule': 'Banei Tokachi schedule'
};
const getSourceLabel = (sourceId: string) =>
  sourceLabelById[sourceId] ?? sourceId.split('-').map((part) => part.toUpperCase()).join(' ');

const officialSourceGroups = profile?.racing_systems.map((system) => ({
  ...system,
  sources: system.source_ids.flatMap((sourceId) => {
    const source = sourcesById.get(sourceId);
    return source ? [source] : [];
  })
})) ?? [];

const displayedRacingTypes = profile
  ? profile.racing_types.map((type) => type.name_en).join(', ')
  : country.racing_types.join(', ');
const timezoneLabel = profile
  ? `${profile.typical_schedule.timezone} / ${profile.typical_schedule.utc_offset_label}`
  : 'Check the racecourse local time';
const overviewParagraphs = profile?.overview_paragraphs_en ?? (profile ? [profile.overview_en, profile.horse_and_format_summary_en] : []);
const getRacecourseSystem = (racecourse: any) => {
  if (racecourse.id === 'obihiro-racecourse' || racecourse.racing_types?.includes('banei-racing')) return 'Banei';
  if (racecourse.related_sources?.some((id: string) => id.startsWith('japan-jra'))) return 'JRA';
  if (racecourse.related_sources?.some((id: string) => id.startsWith('japan-nar'))) return 'Local racing';
  return racecourse.racing_types?.includes('thoroughbred-flat') ? 'Flat racing' : 'Unclassified';
};
---

<BaseLayout
  title={`${country.name_en} Horse Racing Calendar & Racecourses | Where Horses Run`}
  description={profile?.hero_summary_en ?? profile?.overview_en ?? country.summary_en}
>
  <div class="country-page">
    <section class="hero country-hero" aria-labelledby="page-title">
      <p class="hero__eyebrow">Country racing guide</p>
      <h1 id="page-title">{country.name_en} Horse Racing Calendar & Racecourses</h1>
      <p class="hero__summary">{profile?.hero_summary_en ?? profile?.overview_en ?? country.summary_en}</p>
      <nav class="country-jump-nav" aria-label="Page sections">
        <a href="#upcoming-meetings">Upcoming meetings</a>
        <a href="#racecourses">Main racecourses</a>
        <a href="#official-sources">Official sources</a>
      </nav>
    </section>

    <section class="country-grid country-grid--2 country-section" aria-label="Country racing quick facts">
      <article class="card country-card">
        <h2>Quick facts</h2>
        <dl class="country-facts">
          <div><dt>Region</dt><dd>{country.region}</dd></div>
          <div><dt>Local name</dt><dd>{country.name_local}</dd></div>
          <div><dt>Racing types</dt><dd>{displayedRacingTypes}</dd></div>
          <div><dt>Timezone</dt><dd>{timezoneLabel}</dd></div>
          <div><dt>Profile reviewed</dt><dd>{profile?.last_reviewed ?? 'Pending'}</dd></div>
        </dl>
      </article>
      <article class="card country-card">
        <h2>How to use this page</h2>
        <p>Use this page to understand the country's racing systems, season, surfaces, common meeting days and times, racecourses, and official information sources.</p>
        <p>Upcoming meetings below are read from the public timetable view. Final meeting dates, post times, and race information should always be confirmed on official or licensed source pages.</p>
      </article>
    </section>

    {profile ? (
      <>
        <section class="country-section" aria-labelledby="overview-heading">
          <h2 class="country-section__title" id="overview-heading">Horse racing in {country.name_en}</h2>
          <div class="country-prose">{overviewParagraphs.map((paragraph) => <p>{paragraph}</p>)}</div>
        </section>
        <section class="country-section" aria-labelledby="racing-types-heading">
          <h2 class="country-section__title" id="racing-types-heading">What types of horse racing are held here?</h2>
          <div class="country-grid country-grid--3">
            {profile.racing_types.map((type) => <article class="card country-card"><h3>{type.name_en}</h3><p>{type.summary_en}</p></article>)}
          </div>
        </section>
        <section class="country-section" aria-labelledby="meeting-pattern-heading">
          <h2 class="country-section__title" id="meeting-pattern-heading">Meeting patterns</h2>
          <div class="country-grid country-grid--3">
            <article class="card country-card"><h3>Racing season</h3><p>{profile.seasonality.summary_en}</p></article>
            <article class="card country-card"><h3>Typical race days and times</h3><p>{profile.typical_schedule.summary_en}</p><p><strong>Timezone:</strong> {profile.typical_schedule.timezone} / {profile.typical_schedule.utc_offset_label}</p></article>
            <article class="card country-card"><h3>Surfaces, tracks, and formats</h3><p>{profile.surfaces_and_tracks.summary_en}</p></article>
          </div>
        </section>
        <section class="country-section" aria-labelledby="systems-heading">
          <h2 class="country-section__title" id="systems-heading">Racing systems and authorities</h2>
          <div class="country-grid country-grid--3">
            {profile.racing_systems.map((system) => <article class="card country-card"><h3>{system.name_en}</h3><p>{system.summary_en}</p></article>)}
          </div>
        </section>
      </>
    ) : (
      <section class="country-section"><h2 class="country-section__title">Country overview</h2><div class="country-prose"><p>{country.summary_en}</p><p>A detailed country racing profile has not been added yet.</p></div></section>
    )}

    <section class="country-section" id="upcoming-meetings" aria-labelledby="upcoming-meetings-heading">
      <h2 class="country-section__title" id="upcoming-meetings-heading">Upcoming meetings</h2>
      <p class="country-section__intro">One row represents one meeting. Racecards, entries, odds, results, and payouts are not reproduced here.</p>
      <ContextTimetableTable records={publicMeetings} emptyLabel="No public timetable meetings are currently listed for this country. Use the official source links below to confirm the latest schedule." />
    </section>

    <section class="country-section" id="racecourses" aria-labelledby="racecourses-heading">
      <h2 class="country-section__title" id="racecourses-heading">Main racecourses</h2>
      <p class="country-section__intro">The table links to racecourse profiles currently available in Where Horses Run.</p>
      {racecourses.length > 0 ? (
        <div class="country-table-wrap"><table class="country-table country-table--racecourses"><thead><tr><th>Racecourse</th><th>Location</th><th>System</th><th>Details</th></tr></thead><tbody>{racecourses.map((racecourse) => <tr><td data-label="Racecourse">{racecourse.name_en}</td><td data-label="Location">{racecourse.city}</td><td data-label="System">{getRacecourseSystem(racecourse)}</td><td data-label="Details"><a href={`/tracks/${racecourse.slug}/`}>Open racecourse page</a></td></tr>)}</tbody></table></div>
      ) : <p>No racecourse profiles are listed yet.</p>}
    </section>

    <section class="country-section" id="official-sources" aria-labelledby="official-sources-heading">
      <h2 class="country-section__title" id="official-sources-heading">Official sources</h2>
      <p class="country-section__intro">Use these official landing pages for final confirmation. Where Horses Run does not replace official calendars or racecards.</p>
      {officialSourceGroups.length > 0 ? (
        <div class="country-grid country-grid--3">{officialSourceGroups.map((group) => <article class="card country-card"><h3>{group.name_en}</h3><ul>{group.sources.map((source) => <li><a href={source.url}>{getSourceLabel(source.id)}</a></li>)}</ul></article>)}</div>
      ) : sources.length > 0 ? <ul>{sources.map((source) => <li><a href={source.url}>{getSourceLabel(source.id)}</a></li>)}</ul> : <p>No official source entries are listed yet.</p>}
    </section>

    <details class="country-technical">
      <summary>Technical coverage details</summary>
      <div class="country-grid country-grid--3">
        <article class="card country-card"><h3>Dataset status</h3><p><strong>Country status:</strong> {country.status}</p><p><strong>Coverage level:</strong> {country.coverage_level}</p><p><strong>Automation level:</strong> {country.auto_level}</p><p><strong>Public timetable rows:</strong> {publicMeetings.length}</p>{countryInventory && <p><strong>Seed state:</strong> {countryInventory.current_seed_state}</p>}</article>
        <article class="card country-card"><h3>Fetch status</h3>{countryFetchStatuses.length > 0 ? <ul>{countryFetchStatuses.map((status) => <li><strong>{status.source_id}</strong>: {status.status} — {status.message}</li>)}</ul> : <p>No fetch status entries are listed.</p>}</article>
        <article class="card country-card"><h3>Probe status</h3>{countryLiveFetchProbes.length > 0 ? <ul>{countryLiveFetchProbes.map((probe) => <li><strong>{probe.source_id}</strong>: {probe.status} / HTTP {probe.http_status}</li>)}</ul> : <p>No live fetch probe metadata is listed.</p>}</article>
      </div>
    </details>
    <p class="country-back-link"><a href="/countries/">← Back to countries</a></p>
  </div>
</BaseLayout>
