---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getCountries,
  getCountryBySlug,
  getRacecoursesByCountryId,
  getSourcesByCountryId,
  siteData
} from '../../lib/data';

export function getStaticPaths() {
  return getCountries().map((country) => ({
    params: { slug: country.slug }
  }));
}

const { slug } = Astro.params;
const country = getCountryBySlug(slug ?? '');

if (!country) {
  return Astro.redirect('/countries/');
}

const racecourses = getRacecoursesByCountryId(country.id);
const sources = getSourcesByCountryId(country.id);
const fetchStatuses = siteData.generated.fetchStatus.sources ?? [];
const countryFetchStatuses = fetchStatuses.filter((status) => status.country_id === country.id);
const alphaSources = sources.filter((source) => source.m3_status === 'alpha_link_first');
const hasAlphaCoverage = alphaSources.length > 0 || countryFetchStatuses.length > 0;
---

<BaseLayout
  title={`${country.name_en} | Countries | Where Horses Run`}
  description={country.summary_en}
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Country profile</p>
    <h1 id="page-title">{country.name_en}</h1>
    <p class="hero__summary">{country.summary_en}</p>
  </section>

  <section class="section-grid" aria-label="Country details">
    <article class="card">
      <h2>Coverage</h2>
      <p><strong>Status:</strong> {country.status}</p>
      <p><strong>Region:</strong> {country.region}</p>
      <p><strong>Coverage level:</strong> {country.coverage_level}</p>
      <p><strong>Auto level:</strong> {country.auto_level}</p>
    </article>

    <article class="card">
      <h2>Racing types</h2>
      <p>{country.racing_types.join(', ')}</p>
    </article>

    <article class="card">
      <h2>Official-source boundary</h2>
      <p>Race details, entries, odds, results, and payouts should be confirmed on official or licensed source pages.</p>
    </article>
  </section>

  {hasAlphaCoverage && (
    <section class="section-grid" aria-label="Alpha timetable coverage">
      <article class="card">
        <h2>Alpha timetable coverage</h2>
        <p><strong>Mode:</strong> link-first / dry-run</p>
        <p><strong>Live fetching:</strong> disabled</p>
        <p><strong>Current scope:</strong> official source routing, generated fallback visibility, FetchStatus display, and UI verification.</p>
      </article>

      <article class="card">
        <h2>FetchStatus coverage</h2>
        {countryFetchStatuses.length > 0 ? (
          <ul>
            {countryFetchStatuses.map((status) => (
              <li>
                <strong>{status.source_id}</strong>: {status.status} — {status.message}
              </li>
            ))}
          </ul>
        ) : (
          <p>No FetchStatus entry is listed for this country yet.</p>
        )}
      </article>

      <article class="card">
        <h2>Generated coverage fallback</h2>
        <p>No live timetable has been fetched for this country yet. Use official source links for confirmation.</p>
        <p>This page does not republish racecards, entries, odds, results, payouts, or betting tips.</p>
      </article>
    </section>
  )}

  <section class="section-grid" aria-label="Racecourses and sources">
    <article class="card">
      <h2>Racecourses</h2>
      {racecourses.length > 0 ? (
        <ul>
          {racecourses.map((racecourse) => <li>{racecourse.name_en} — {racecourse.city}</li>)}
        </ul>
      ) : (
        <p>No racecourse entries are listed yet.</p>
      )}
    </article>

    <article class="card">
      <h2>Official sources</h2>
      {sources.length > 0 ? (
        <ul>
          {sources.map((source) => (
            <li>
              <a href={source.url}>{source.id}</a>
              <br />
              <span>{source.data_type} / Auto {source.auto_level}</span>
              <br />
              <span>{source.notes}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p>No source entries are listed yet.</p>
      )}
    </article>
  </section>

  <p><a href="/countries/">Back to countries</a></p>
</BaseLayout>
