---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getRacecoursesByRacingTypeId,
  getRacingTypeBySlug,
  getRacingTypeGlossaryEntry,
  getRacingTypeRelatedGlossaryEntries,
  getRacingTypes
} from '../../lib/racingTypes';
import { getCountries } from '../../lib/data';

export function getStaticPaths() {
  return getRacingTypes().map((type) => ({ params: { slug: type.slug } }));
}

const { slug } = Astro.params;
const type = getRacingTypeBySlug(slug ?? '');

if (!type) {
  return Astro.redirect('/types/');
}

const tracks = getRacecoursesByRacingTypeId(type.id);
const countries = getCountries();
const countryById = new Map(countries.map((country) => [country.id, country]));
const countryIds = [...new Set(tracks.map((track) => track.country_id))];
const glossaryEntry = getRacingTypeGlossaryEntry(type);
const relatedTerms = getRacingTypeRelatedGlossaryEntries(type);
const surfaces = [...new Set(tracks.flatMap((track) => track.surfaces ?? []))].sort();
---

<BaseLayout title={`${type.name_en} | Racing Types`} description={type.summary_en}>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Racing type</p>
    <h1 id="page-title">{type.name_en}</h1>
    <p class="hero__summary">{type.summary_en}</p>
  </section>

  <section class="section-grid" aria-label="Racing type detail">
    <article class="card">
      <h2>Overview</h2>
      <p>{type.summary_en}</p>
      <p><strong>Listed racecourses:</strong> {tracks.length}</p>
      <p><strong>Related countries:</strong> {countryIds.length}</p>
      <p><strong>Surface tags:</strong> {surfaces.length ? surfaces.join(', ') : 'Not confirmed'}</p>
    </article>

    <article class="card">
      <h2>Related racecourses</h2>
      {tracks.length ? (
        <ul>
          {tracks.map((track) => (
            <li>
              <a href={`/tracks/${track.slug}/`}>{track.name_en}</a> — {track.city} / {countryById.get(track.country_id)?.name_en ?? track.country_id}
              <br />
              <span>Surfaces: {track.surfaces.length ? track.surfaces.join(', ') : 'Not confirmed'} · Schedule: {track.schedule_summary?.status ?? 'official-link-only'}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p>No racecourse entries are currently tagged with this racing type.</p>
      )}
    </article>

    <article class="card">
      <h2>Related countries</h2>
      {countryIds.length ? (
        <ul>
          {countryIds.map((countryId) => {
            const country = countryById.get(countryId);
            const count = tracks.filter((track) => track.country_id === countryId).length;
            return <li>{country ? <a href={`/countries/${country.slug}/`}>{country.name_en}</a> : countryId} — {count} racecourse{count === 1 ? '' : 's'}</li>;
          })}
        </ul>
      ) : (
        <p>No related country entries are listed yet.</p>
      )}
    </article>

    <article class="card">
      <h2>Related glossary terms</h2>
      {relatedTerms.length ? (
        <ul>
          {relatedTerms.map((term) => (
            <li><a href={`/glossary/${term.slug}/`}>{term.term_en}</a> — {term.summary_en}</li>
          ))}
        </ul>
      ) : (
        <p>No related glossary terms are linked yet.</p>
      )}
    </article>

    <article class="card">
      <h2>Main glossary context</h2>
      {glossaryEntry ? (
        <>
          <p>{glossaryEntry.summary_en}</p>
          <p><a href={`/glossary/${glossaryEntry.slug}/`}>Open glossary term</a></p>
        </>
      ) : (
        <p>No glossary entry is linked yet.</p>
      )}
    </article>

    <article class="card">
      <h2>Source boundary</h2>
      <p>Use official or licensed source pages for entries, odds, results, payouts, tips, and full racecards.</p>
    </article>
  </section>

  <p><a href="/types/">Back to racing types</a></p>
</BaseLayout>
