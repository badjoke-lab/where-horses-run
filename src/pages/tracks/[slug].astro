---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getCountries,
  getGlossaryEntries,
  getRacecourseBySlug,
  getRacecourses,
  siteData
} from '../../lib/data';
import { getRacingTypeById } from '../../lib/racingTypes';

export function getStaticPaths() {
  return getRacecourses().map((track) => ({ params: { slug: track.slug } }));
}

const { slug } = Astro.params;
const track = getRacecourseBySlug(slug ?? '');

if (!track) {
  return Astro.redirect('/tracks/');
}

const profile = track as any;
const countries = getCountries();
const country = countries.find((entry) => entry.id === track.country_id);
const countryHref = country ? `/countries/${country.slug}/` : '/countries/';
const countrySourceHref = country ? `/sources/${country.slug}/` : '/sources/';
const calendarHref = country ? `/countries/${country.slug}/` : '/calendar/';
const glossaryById = new Map(getGlossaryEntries().map((entry) => [entry.id, entry]));
const sourcesById = new Map(siteData.sources.map((source) => [source.id, source]));

const formatValue = (value: unknown) => {
  if (value === null || value === undefined || value === '') return 'Not confirmed';
  if (Array.isArray(value)) return value.length > 0 ? value.join(', ') : 'Not confirmed';
  return String(value);
};

const formatNumber = (value: unknown) => typeof value === 'number' ? value.toLocaleString('en-US') : 'Not confirmed';
const formatMeters = (value: unknown) => typeof value === 'number' ? `${value.toLocaleString('en-US')}m` : 'Not confirmed';

const directionLabel = (value: unknown) => {
  const labels: Record<string, string> = {
    'left-handed': 'Left-handed',
    'right-handed': 'Right-handed',
    straight: 'Straight',
    unknown: 'Not confirmed'
  };
  return typeof value === 'string' ? labels[value] ?? value : 'Not confirmed';
};

const statusLabel = (value: unknown) => {
  const labels: Record<string, string> = {
    racing_today: 'Racing today',
    no_racing_today: 'No racing today',
    unknown: 'Schedule not verified yet',
    verified: 'Verified',
    partial: 'Partial',
    secondary: 'Secondary source',
    stale: 'Needs recheck',
    failed: 'Failed',
    'official-link-only': 'Official-link only',
    link_first: 'Link-first'
  };
  return typeof value === 'string' ? labels[value] ?? value : 'Not confirmed';
};

const toRecord = (value: unknown): Record<string, any> => {
  if (!value || typeof value !== 'object' || Array.isArray(value)) return {};
  return value as Record<string, any>;
};

const firstValue = (record: unknown, keys: string[]) => {
  const row = toRecord(record);
  for (const key of keys) {
    if (row[key] !== null && row[key] !== undefined && row[key] !== '') return row[key];
  }
  return null;
};

const formatRecordFields = (record: unknown, fields: Array<[string, string[]]>) => {
  const parts = fields
    .map(([label, keys]) => {
      const value = firstValue(record, keys);
      return value === null ? null : `${label}: ${String(value)}`;
    })
    .filter(Boolean);
  return parts.length ? parts.join(' · ') : 'Details are pending formatting.';
};

const formatDistanceList = (value: unknown) => {
  if (!Array.isArray(value) || value.length === 0) return 'Not verified yet';
  return value.map((distance) => `${distance}m`).join(', ');
};

const officialLinks = track.official_links ?? [];
const relatedTerms = track.related_terms ?? [];
const relatedSources = track.related_sources ?? [];
const operator = toRecord(profile.operator);
const capacity = toRecord(profile.capacity_profile);
const courseLayout = toRecord(profile.course_layout);
const raceDistanceProfile = toRecord(profile.race_distance_profile);
const visitorLinks = toRecord(profile.visitor_links);

const primaryScheduleUrl = typeof visitorLinks.official_schedule === 'string'
  ? visitorLinks.official_schedule
  : officialLinks.find((link) => link.link_type === 'schedule')?.url ?? officialLinks[0]?.url;
const primaryVenueUrl = typeof visitorLinks.official_racecourse === 'string'
  ? visitorLinks.official_racecourse
  : officialLinks.find((link) => link.link_type === 'official')?.url ?? officialLinks[0]?.url;
const primaryCourseUrl = typeof visitorLinks.official_course_details === 'string'
  ? visitorLinks.official_course_details
  : officialLinks.find((link) => link.url.includes('course_details'))?.url;

const meetingFields: Array<[string, string[]]> = [
  ['Date', ['date', 'local_date', 'meeting_date']],
  ['First post', ['first_post', 'first_race_time', 'first_race']],
  ['Last race', ['last_race_time', 'last_race']],
  ['Races', ['race_count', 'races']],
  ['Status', ['status']]
];
const raceConditionFields: Array<[string, string[]]> = [
  ['Date', ['date', 'local_date']],
  ['Race', ['race_number', 'race_no', 'race']],
  ['Time', ['post_time', 'start_time', 'time']],
  ['Surface', ['surface']],
  ['Distance', ['distance', 'distance_m']],
  ['Type', ['race_type', 'type']]
];
const notableRaceFields: Array<[string, string[]]> = [
  ['Name', ['name_en', 'name', 'race_name']],
  ['Grade', ['grade']],
  ['Surface', ['surface']],
  ['Distance', ['distance_m', 'distance']],
  ['Season', ['season', 'month']],
  ['Source', ['official_link', 'source_url', 'url']]
];

const courseGroups = [
  ['Turf courses', courseLayout.turf_courses],
  ['Dirt courses', courseLayout.dirt_courses],
  ['Jump courses', courseLayout.jump_courses],
  ['All-weather courses', courseLayout.all_weather_courses],
  ['Harness courses', courseLayout.harness_courses],
  ['Banei courses', courseLayout.banei_courses]
].filter(([, rows]) => Array.isArray(rows) && rows.length > 0) as Array<[string, any[]]>;

const fallbackCourseRows = [
  ['Turf circumference', track.course_profile?.turf_circumference_m],
  ['Dirt circumference', track.course_profile?.dirt_circumference_m],
  ['Home straight', track.course_profile?.home_straight_m]
].filter(([, value]) => typeof value === 'number');

const visitorLinkRows = [
  ['Official racecourse page', visitorLinks.official_racecourse],
  ['Official schedule / fixtures', visitorLinks.official_schedule],
  ['Official course details', visitorLinks.official_course_details],
  ['Official access', visitorLinks.official_access],
  ['Official racecard', visitorLinks.official_racecard],
  ['Official results', visitorLinks.official_results]
].filter(([, url]) => typeof url === 'string' && url.length > 0) as Array<[string, string]>;

const overview = profile.overview_en ?? track.course_profile?.course_notes_en ?? 'This racecourse profile is being built from official and source-safe racing information.';
---

<BaseLayout title={`${track.name_en} | Racecourses`} description={`Venue profile, scale, course layout, schedule gateway, official links, and related racing terms for ${track.name_en}.`}>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Racecourse profile</p>
    <h1 id="page-title">{track.name_en}</h1>
    <p class="hero__summary">
      {track.name_local && track.name_local !== track.name_en ? `${track.name_local} · ` : ''}
      {country ? country.name_en : track.country_id} / {track.city}
    </p>
    <p>{overview}</p>
    <p>
      {primaryScheduleUrl ? <a href={primaryScheduleUrl}>Official schedule</a> : <a href={calendarHref}>Open calendar view</a>}
      {' · '}
      {primaryVenueUrl ? <a href={primaryVenueUrl}>Official venue page</a> : <a href={countrySourceHref}>Country source registry</a>}
      {primaryCourseUrl ? <><span>{' · '}</span><a href={primaryCourseUrl}>Official course details</a></> : null}
    </p>
  </section>

  <section class="section-grid" aria-label="Quick facts and schedule gateway">
    <article class="card">
      <h2>Quick facts</h2>
      <p><strong>Country:</strong> <a href={countryHref}>{country ? country.name_en : track.country_id}</a></p>
      <p><strong>City / region:</strong> {track.city} / {formatValue(track.region)}</p>
      <p><strong>Timezone:</strong> {track.timezone}</p>
      <p><strong>Operator:</strong> {formatValue(operator.name)}{operator.type ? ` (${operator.type})` : ''}</p>
      <p><strong>Status:</strong> {track.status}</p>
      <p><strong>Surfaces:</strong> {formatValue(track.surfaces)}</p>
      <p><strong>Direction:</strong> {directionLabel(track.direction)}</p>
      <p><strong>Representative turf length:</strong> {formatMeters(track.course_profile?.turf_circumference_m)}</p>
      <p><strong>Home straight:</strong> {formatMeters(courseLayout.home_straight_m ?? track.course_profile?.home_straight_m)}</p>
    </article>

    <article class="card">
      <h2>Venue scale</h2>
      <p><strong>Total capacity:</strong> {formatNumber(capacity.total_capacity)}</p>
      <p><strong>Seating capacity:</strong> {formatNumber(capacity.seating_capacity)}</p>
      <p><strong>Standing capacity:</strong> {formatNumber(capacity.standing_capacity)}</p>
      <p><strong>Status:</strong> {statusLabel(capacity.status)}</p>
      <p>{capacity.scale_note_en ?? 'Venue capacity is not confirmed yet.'}</p>
      {capacity.source_url ? <p><a href={capacity.source_url}>Capacity source</a></p> : null}
    </article>

    <article class="card">
      <h2>Schedule gateway</h2>
      <p><strong>Today:</strong> {statusLabel(track.schedule_summary?.today_status)}</p>
      <p><strong>Next meeting:</strong> {formatValue(track.schedule_summary?.next_meeting_date)}</p>
      <p><strong>Schedule status:</strong> {statusLabel(track.schedule_summary?.status)}</p>
      <p><strong>Last checked:</strong> {formatValue(track.schedule_summary?.last_checked)}</p>
      <p>{primaryScheduleUrl ? <a href={primaryScheduleUrl}>Check official schedule</a> : <a href={calendarHref}>Open available calendar data</a>}</p>
    </article>
  </section>

  <section class="section-grid" aria-label="Racing types and upcoming meetings">
    <article class="card">
      <h2>Racing types</h2>
      <ul>
        {track.racing_types.map((typeId) => {
          const type = getRacingTypeById(typeId);
          return <li>{type ? <a href={`/types/${type.slug}/`}>{type.name_en}</a> : typeId}</li>;
        })}
      </ul>
    </article>

    <article class="card">
      <h2>Upcoming meetings</h2>
      {track.schedule_summary?.upcoming_meetings?.length ? (
        <ul>
          {track.schedule_summary.upcoming_meetings.map((meeting) => (
            <li>{formatRecordFields(meeting, meetingFields)}</li>
          ))}
        </ul>
      ) : (
        <p>No verified upcoming meeting rows are listed for this racecourse yet. Use the official schedule link for final confirmation.</p>
      )}
    </article>

    <article class="card">
      <h2>Upcoming race conditions</h2>
      {track.distance_profile?.upcoming_conditions?.length ? (
        <ul>
          {track.distance_profile.upcoming_conditions.map((condition) => (
            <li>{formatRecordFields(condition, raceConditionFields)}</li>
          ))}
        </ul>
      ) : (
        <p>No verified race-condition rows are listed yet. Entries, odds, results, payouts, and full racecards are not republished here.</p>
      )}
    </article>
  </section>

  <section class="section-grid" aria-label="Course layout and race distances">
    <article class="card">
      <h2>Course layout</h2>
      {courseGroups.length ? (
        <div>
          {courseGroups.map(([label, rows]) => (
            <div>
              <h3>{label}</h3>
              <ul>
                {rows.map((course) => (
                  <li>
                    <strong>{course.label}</strong>
                    {' — '}{formatMeters(course.circumference_m)}
                    {course.direction ? ` · ${directionLabel(course.direction)}` : ''}
                    {course.surface ? ` · ${course.surface}` : ''}
                    {course.note_en ? <><br /><span>{course.note_en}</span></> : null}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <div>
          <p>{track.course_profile?.course_notes_en ?? 'Course layout details are pending official-source verification.'}</p>
          {fallbackCourseRows.length ? <ul>{fallbackCourseRows.map(([label, value]) => <li><strong>{label}:</strong> {formatMeters(value)}</li>)}</ul> : null}
        </div>
      )}
      <p><strong>Inner / outer note:</strong> {courseLayout.inner_outer_note_en ?? (track.course_profile?.has_inner_outer_courses === null ? 'Not confirmed' : String(track.course_profile?.has_inner_outer_courses))}</p>
      <p><strong>Layout status:</strong> {statusLabel(courseLayout.status ?? track.data_status?.course_profile)}</p>
    </article>

    <article class="card">
      <h2>Race distance profile</h2>
      <p>This section is for actual race distances used at the venue, not course circumferences.</p>
      <p><strong>Turf:</strong> {formatDistanceList(raceDistanceProfile.turf_distances_m)}</p>
      <p><strong>Dirt:</strong> {formatDistanceList(raceDistanceProfile.dirt_distances_m)}</p>
      <p><strong>Jump:</strong> {formatDistanceList(raceDistanceProfile.jump_distances_m)}</p>
      <p><strong>All-weather:</strong> {formatDistanceList(raceDistanceProfile.all_weather_distances_m)}</p>
      <p><strong>Harness:</strong> {formatDistanceList(raceDistanceProfile.harness_distances_m)}</p>
      <p><strong>Status:</strong> {statusLabel(raceDistanceProfile.status)}</p>
    </article>
  </section>

  <section class="section-grid" aria-label="Races, seasonality, and official links">
    <article class="card">
      <h2>Notable races</h2>
      {track.notable_races?.length ? (
        <ul>
          {track.notable_races.map((race) => (
            <li>{formatRecordFields(race, notableRaceFields)}</li>
          ))}
        </ul>
      ) : (
        <p>No notable-race entries are listed yet. Future entries should link to official or source-safe pages.</p>
      )}
    </article>

    <article class="card">
      <h2>Seasonality</h2>
      <p>{track.seasonality?.summary_en ?? 'Seasonality is pending official-source verification.'}</p>
      <p><strong>Status:</strong> {statusLabel(track.seasonality?.status)}</p>
    </article>

    <article class="card">
      <h2>Official and visitor links</h2>
      {visitorLinkRows.length ? (
        <ul>
          {visitorLinkRows.map(([label, url]) => <li><a href={url}>{label}</a></li>)}
        </ul>
      ) : null}
      {officialLinks.length ? (
        <ul>
          {officialLinks.map((link) => (
            <li>
              <a href={link.url}>{link.label_en}</a>
              <br />
              <span>Type: {link.link_type} / Source: {link.source_id}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p>No official links are attached to this racecourse yet.</p>
      )}
    </article>
  </section>

  <section class="section-grid" aria-label="Data status and related pages">
    <article class="card">
      <h2>Data status</h2>
      <p><strong>Course profile:</strong> {statusLabel(track.data_status?.course_profile)}</p>
      <p><strong>Schedule:</strong> {statusLabel(track.data_status?.schedule)}</p>
      <p><strong>Source routing:</strong> {statusLabel(track.data_status?.source_status)}</p>
      <p><strong>Capacity:</strong> {statusLabel(capacity.status)}</p>
      <p><strong>Race distances:</strong> {statusLabel(raceDistanceProfile.status)}</p>
      <p><strong>Last checked:</strong> {formatValue(track.data_status?.last_checked)}</p>
      <p>Where Horses Run links to official sources but does not republish full entries, odds, results, payouts, predictions, or complete racecards.</p>
    </article>

    <article class="card">
      <h2>Related learning</h2>
      <p><a href={countryHref}>Open country page</a></p>
      {relatedTerms.length ? (
        <ul>
          {relatedTerms.map((termId) => {
            const term = glossaryById.get(termId);
            return <li>{term ? <a href={`/glossary/${term.slug}/`}>{term.term_en}</a> : termId}</li>;
          })}
        </ul>
      ) : (
        <p>No related terms are listed yet.</p>
      )}
    </article>

    <article class="card">
      <h2>Related sources</h2>
      <p><a href={countrySourceHref}>Open country source registry</a></p>
      {relatedSources.length ? (
        <ul>
          {relatedSources.map((sourceId) => {
            const source = sourcesById.get(sourceId);
            return <li>{source ? <a href={source.url}>{source.id}</a> : sourceId}</li>;
          })}
        </ul>
      ) : (
        <p>No related sources are listed yet.</p>
      )}
    </article>
  </section>

  <p><a href="/tracks/">Back</a></p>
</BaseLayout>
