---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getCountries,
  getGlossaryEntries,
  getRacecourseBySlug,
  getRacecourses,
  siteData
} from '../../lib/data';
import { getRacingTypeById } from '../../lib/racingTypes';

export function getStaticPaths() {
  return getRacecourses().map((track) => ({ params: { slug: track.slug } }));
}

const { slug } = Astro.params;
const track = getRacecourseBySlug(slug ?? '');

if (!track) {
  return Astro.redirect('/tracks/');
}

const profile = track as any;
const countries = getCountries();
const country = countries.find((entry) => entry.id === track.country_id);
const countryHref = country ? `/countries/${country.slug}/` : '/countries/';
const countrySourceHref = country ? `/sources/${country.slug}/` : '/sources/';
const calendarHref = country ? `/countries/${country.slug}/` : '/calendar/';
const glossaryById = new Map(getGlossaryEntries().map((entry) => [entry.id, entry]));
const sourcesById = new Map(siteData.sources.map((source) => [source.id, source]));

const formatValue = (value: unknown) => {
  if (value === null || value === undefined || value === '') return 'Not listed yet';
  if (Array.isArray(value)) return value.length > 0 ? value.join(', ') : 'Not listed yet';
  return String(value);
};

const formatNumber = (value: unknown) => typeof value === 'number' ? value.toLocaleString('en-US') : 'Not listed yet';
const formatMeters = (value: unknown) => typeof value === 'number' ? `${value.toLocaleString('en-US')}m` : 'Not listed yet';

const directionLabel = (value: unknown) => {
  const labels: Record<string, string> = {
    'left-handed': 'Left-handed',
    'right-handed': 'Right-handed',
    straight: 'Straight',
    unknown: 'Not listed yet'
  };
  return typeof value === 'string' ? labels[value] ?? value : 'Not listed yet';
};

const statusLabel = (value: unknown) => {
  const labels: Record<string, string> = {
    racing_today: 'Racing today',
    no_racing_today: 'No racing today',
    unknown: 'Not checked yet',
    verified: 'Checked',
    partial: 'Partly checked',
    secondary: 'Secondary source',
    stale: 'Needs recheck',
    failed: 'Unavailable',
    'official-link-only': 'Use linked schedule',
    link_first: 'Link-first'
  };
  return typeof value === 'string' ? labels[value] ?? value : 'Not listed yet';
};

const toRecord = (value: unknown): Record<string, any> => {
  if (!value || typeof value !== 'object' || Array.isArray(value)) return {};
  return value as Record<string, any>;
};

const firstValue = (record: unknown, keys: string[]) => {
  const row = toRecord(record);
  for (const key of keys) {
    if (row[key] !== null && row[key] !== undefined && row[key] !== '') return row[key];
  }
  return null;
};

const formatRecordFields = (record: unknown, fields: Array<[string, string[]]>) => {
  const parts = fields
    .map(([label, keys]) => {
      const value = firstValue(record, keys);
      return value === null ? null : `${label}: ${String(value)}`;
    })
    .filter(Boolean);
  return parts.length ? parts.join(' · ') : 'Details will be added later.';
};

const formatDistanceList = (value: unknown) => {
  if (!Array.isArray(value) || value.length === 0) return null;
  return value.map((distance) => `${distance}m`).join(', ');
};

const officialLinks = track.official_links ?? [];
const relatedTerms = track.related_terms ?? [];
const relatedSources = track.related_sources ?? [];
const operator = toRecord(profile.operator);
const capacity = toRecord(profile.capacity_profile);
const courseLayout = toRecord(profile.course_layout);
const raceDistanceProfile = toRecord(profile.race_distance_profile);
const visitorLinks = toRecord(profile.visitor_links);
const upcomingMeetings = track.schedule_summary?.upcoming_meetings ?? [];
const upcomingConditions = track.distance_profile?.upcoming_conditions ?? [];

const primaryScheduleUrl = typeof visitorLinks.official_schedule === 'string'
  ? visitorLinks.official_schedule
  : officialLinks.find((link) => link.link_type === 'schedule')?.url ?? officialLinks[0]?.url;
const primaryVenueUrl = typeof visitorLinks.official_racecourse === 'string'
  ? visitorLinks.official_racecourse
  : officialLinks.find((link) => link.link_type === 'official')?.url ?? officialLinks[0]?.url;
const primaryCourseUrl = typeof visitorLinks.official_course_details === 'string'
  ? visitorLinks.official_course_details
  : officialLinks.find((link) => link.url.includes('course_details'))?.url;

const meetingFields: Array<[string, string[]]> = [
  ['Date', ['date', 'local_date', 'meeting_date']],
  ['First post', ['first_post', 'first_race_time', 'first_race']],
  ['Last race', ['last_race_time', 'last_race']],
  ['Races', ['race_count', 'races']],
  ['Status', ['status']]
];
const raceConditionFields: Array<[string, string[]]> = [
  ['Date', ['date', 'local_date']],
  ['Race', ['race_number', 'race_no', 'race']],
  ['Time', ['post_time', 'start_time', 'time']],
  ['Surface', ['surface']],
  ['Distance', ['distance', 'distance_m']],
  ['Type', ['race_type', 'type']]
];

const courseGroups = [
  ['Turf courses', courseLayout.turf_courses],
  ['Dirt courses', courseLayout.dirt_courses],
  ['Jump courses', courseLayout.jump_courses],
  ['All-weather courses', courseLayout.all_weather_courses],
  ['Harness courses', courseLayout.harness_courses],
  ['Banei courses', courseLayout.banei_courses]
].filter(([, rows]) => Array.isArray(rows) && rows.length > 0) as Array<[string, any[]]>;

const fallbackCourseRows = [
  ['Turf circumference', track.course_profile?.turf_circumference_m],
  ['Dirt circumference', track.course_profile?.dirt_circumference_m],
  ['Home straight', track.course_profile?.home_straight_m]
].filter(([, value]) => typeof value === 'number');

const raceDistanceRows = [
  ['Turf', raceDistanceProfile.turf_distances_m],
  ['Dirt', raceDistanceProfile.dirt_distances_m],
  ['Jump', raceDistanceProfile.jump_distances_m],
  ['All-weather', raceDistanceProfile.all_weather_distances_m],
  ['Harness', raceDistanceProfile.harness_distances_m]
]
  .map(([label, value]) => [label, formatDistanceList(value)] as const)
  .filter(([, value]) => value);

const visitorLinkRows = [
  ['Racecourse page', visitorLinks.official_racecourse],
  ['Schedule', visitorLinks.official_schedule],
  ['Course details', visitorLinks.official_course_details],
  ['Access', visitorLinks.official_access],
  ['Racecard', visitorLinks.official_racecard],
  ['Results', visitorLinks.official_results]
].filter(([, url]) => typeof url === 'string' && url.length > 0) as Array<[string, string]>;

const fallbackOfficialRows = officialLinks.map((link) => [link.label_en, link.url] as [string, string]);
const linkRows = visitorLinkRows.length ? visitorLinkRows : fallbackOfficialRows;
const overview = profile.overview_en ?? track.course_profile?.course_notes_en ?? 'This page collects venue basics, course information, and schedule links for this racecourse.';
const hasCapacity = typeof capacity.total_capacity === 'number' || typeof capacity.seating_capacity === 'number' || typeof capacity.standing_capacity === 'number';
---

<BaseLayout title={`${track.name_en} | Racecourses`} description={`Venue profile, scale, course layout, schedule links, and related racing terms for ${track.name_en}.`}>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Racecourse profile</p>
    <h1 id="page-title">{track.name_en}</h1>
    <p class="hero__summary">
      {track.name_local && track.name_local !== track.name_en ? `${track.name_local} · ` : ''}
      {country ? country.name_en : track.country_id} / {track.city}
    </p>
    <p>{overview}</p>
    <p>
      {primaryScheduleUrl ? <a href={primaryScheduleUrl}>Schedule</a> : <a href={calendarHref}>Calendar view</a>}
      {' · '}
      {primaryVenueUrl ? <a href={primaryVenueUrl}>Racecourse page</a> : <a href={countrySourceHref}>Source registry</a>}
      {primaryCourseUrl ? <><span>{' · '}</span><a href={primaryCourseUrl}>Course details</a></> : null}
    </p>
  </section>

  <section class="section-grid" aria-label="Racecourse essentials">
    <article class="card">
      <h2>Quick facts</h2>
      <p><strong>Country:</strong> <a href={countryHref}>{country ? country.name_en : track.country_id}</a></p>
      <p><strong>City / region:</strong> {track.city} / {formatValue(track.region)}</p>
      <p><strong>Timezone:</strong> {track.timezone}</p>
      <p><strong>Operator:</strong> {formatValue(operator.name)}</p>
      <p><strong>Status:</strong> {track.status}</p>
      <p><strong>Surfaces:</strong> {formatValue(track.surfaces)}</p>
      <p><strong>Direction:</strong> {directionLabel(track.direction)}</p>
      <p><strong>Representative course length:</strong> Turf {formatMeters(track.course_profile?.turf_circumference_m)} / Dirt {formatMeters(track.course_profile?.dirt_circumference_m)}</p>
      <p><strong>Home straight:</strong> {formatMeters(courseLayout.home_straight_m ?? track.course_profile?.home_straight_m)}</p>
    </article>

    {hasCapacity ? (
      <article class="card">
        <h2>Venue scale</h2>
        <p><strong>Total capacity:</strong> {formatNumber(capacity.total_capacity)}</p>
        <p><strong>Seating capacity:</strong> {formatNumber(capacity.seating_capacity)}</p>
        {typeof capacity.standing_capacity === 'number' ? <p><strong>Standing capacity:</strong> {formatNumber(capacity.standing_capacity)}</p> : null}
        <p>{capacity.scale_note_en ?? 'Capacity figures will be refined as better references are added.'}</p>
        {capacity.source_url ? <p><a href={capacity.source_url}>Capacity reference</a></p> : null}
      </article>
    ) : null}

    <article class="card">
      <h2>Schedule</h2>
      {upcomingMeetings.length ? (
        <ul>
          {upcomingMeetings.map((meeting) => <li>{formatRecordFields(meeting, meetingFields)}</li>)}
        </ul>
      ) : (
        <p>Upcoming meetings are not shown on this page yet. Once the calendar data is connected, meeting rows will appear here.</p>
      )}
      <p>{primaryScheduleUrl ? <a href={primaryScheduleUrl}>Check the latest schedule</a> : <a href={calendarHref}>Open calendar view</a>}</p>
    </article>
  </section>

  <section class="section-grid" aria-label="Racing types and race conditions">
    <article class="card">
      <h2>Racing types</h2>
      <ul>
        {track.racing_types.map((typeId) => {
          const type = getRacingTypeById(typeId);
          return <li>{type ? <a href={`/types/${type.slug}/`}>{type.name_en}</a> : typeId}</li>;
        })}
      </ul>
    </article>

    {upcomingConditions.length ? (
      <article class="card">
        <h2>Upcoming race conditions</h2>
        <ul>
          {upcomingConditions.map((condition) => <li>{formatRecordFields(condition, raceConditionFields)}</li>)}
        </ul>
      </article>
    ) : null}
  </section>

  <section class="section-grid" aria-label="Course layout and race distances">
    <article class="card">
      <h2>Course layout</h2>
      {courseGroups.length ? (
        <div>
          {courseGroups.map(([label, rows]) => (
            <div>
              <h3>{label}</h3>
              <ul>
                {rows.map((course) => (
                  <li>
                    <strong>{course.label}</strong>
                    {' — '}{formatMeters(course.circumference_m)}
                    {course.direction ? ` · ${directionLabel(course.direction)}` : ''}
                    {course.surface ? ` · ${course.surface}` : ''}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ) : (
        <div>
          <p>{track.course_profile?.course_notes_en ?? 'Course layout details will be added later.'}</p>
          {fallbackCourseRows.length ? <ul>{fallbackCourseRows.map(([label, value]) => <li><strong>{label}:</strong> {formatMeters(value)}</li>)}</ul> : null}
        </div>
      )}
      <p>{courseLayout.inner_outer_note_en ?? 'Detailed rail settings and diagrams should be checked on the course-details page when available.'}</p>
      {primaryCourseUrl ? <p><a href={primaryCourseUrl}>Open course details</a></p> : null}
    </article>

    {raceDistanceRows.length ? (
      <article class="card">
        <h2>Race distances</h2>
        <p>Race distances are separate from course circumferences.</p>
        {raceDistanceRows.map(([label, value]) => <p><strong>{label}:</strong> {value}</p>)}
      </article>
    ) : null}
  </section>

  <section class="section-grid" aria-label="Races, seasonality, and official links">
    <article class="card">
      <h2>Notable races</h2>
      {track.notable_races?.length ? (
        <ul>
          {track.notable_races.map((race) => {
            const row = toRecord(race);
            const name = row.name_en ?? row.name ?? row.race_name;
            const url = row.source_url ?? row.official_link ?? row.url;
            return <li>{typeof url === 'string' ? <a href={url}>{name}</a> : name}</li>;
          })}
        </ul>
      ) : (
        <p>Notable races will be added as this venue profile is expanded.</p>
      )}
      <p>Grade, distance, surface, and season details can be added later where available.</p>
    </article>

    <article class="card">
      <h2>Seasonality</h2>
      <p>{track.seasonality?.summary_en ?? 'Seasonality details will be added later.'}</p>
      <p><strong>Status:</strong> {statusLabel(track.seasonality?.status)}</p>
    </article>

    <article class="card">
      <h2>Official and visitor links</h2>
      {linkRows.length ? (
        <ul>
          {linkRows.map(([label, url]) => <li><a href={url}>{label}</a></li>)}
        </ul>
      ) : (
        <p>Links will be added later.</p>
      )}
    </article>
  </section>

  <section class="section-grid" aria-label="Related pages and data status">
    <article class="card">
      <h2>Related learning</h2>
      <p><a href={countryHref}>Open country page</a></p>
      {relatedTerms.length ? (
        <ul>
          {relatedTerms.map((termId) => {
            const term = glossaryById.get(termId);
            return <li>{term ? <a href={`/glossary/${term.slug}/`}>{term.term_en}</a> : termId}</li>;
          })}
        </ul>
      ) : (
        <p>Related terms will be added later.</p>
      )}
    </article>

    <article class="card">
      <h2>Related sources</h2>
      <p><a href={countrySourceHref}>Open country source registry</a></p>
      {relatedSources.length ? (
        <ul>
          {relatedSources.map((sourceId) => {
            const source = sourcesById.get(sourceId);
            return <li>{source ? <a href={source.url}>{source.id}</a> : sourceId}</li>;
          })}
        </ul>
      ) : (
        <p>Related sources will be added later.</p>
      )}
    </article>

    <article class="card">
      <h2>Data status</h2>
      <p><strong>Course information:</strong> {statusLabel(track.data_status?.course_profile)}</p>
      <p><strong>Schedule:</strong> {statusLabel(track.data_status?.schedule)}</p>
      <p><strong>Capacity:</strong> {statusLabel(capacity.status)}</p>
      <p><strong>Race distances:</strong> {statusLabel(raceDistanceProfile.status)}</p>
      <p><strong>Last checked:</strong> {formatValue(track.data_status?.last_checked)}</p>
      <p>Where Horses Run organizes racecourse information and schedule links. It does not republish full entries, odds, results, payouts, predictions, or complete racecards.</p>
    </article>
  </section>

  <p><a href="/tracks/">Back</a></p>
</BaseLayout>
