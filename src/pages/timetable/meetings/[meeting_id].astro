---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  getPublicTimetableMeetingDetail,
  getPublicTimetableMeetingDetails,
} from '../../../lib/timetable/publicTimetableViewModel';
import { getTimetableMeetingRows, type TimetableMeetingRow } from '../../../data/timetableMeetingRows';
import { getCountries, getRacecourseBySlug } from '../../../lib/data';

export function getStaticPaths() {
  const detailIds = new Set(getPublicTimetableMeetingDetails().map((detail) => detail.meeting_id));
  const meetings = getTimetableMeetingRows().filter((meeting) => detailIds.has(meeting.meeting_id));

  return meetings.map((meeting) => ({
    params: { meeting_id: meeting.meeting_id },
    props: { meeting },
  }));
}

interface Props {
  meeting: TimetableMeetingRow;
}

const { meeting } = Astro.props;
const meetingDetail = getPublicTimetableMeetingDetail(meeting.meeting_id);
const detailPath = `/timetable/meetings/${meeting.meeting_id}/`;
const displayValue = (value: string | number | null | undefined) => value ?? 'Not displayed';
const titleCaseId = (value: string) =>
  value
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
const racecourseName = meeting.racecourse_name;
const authorityNameById: Record<string, string> = {
  jra: 'Japan Racing Association',
  hkjc: 'Hong Kong Jockey Club',
  'nar-local-government-racing': 'National Association of Racing',
};
const countryNameById: Record<string, string> = {
  japan: 'Japan',
  'hong-kong': 'Hong Kong',
};
const timezoneByCountryId: Record<string, string> = {
  japan: 'Asia/Tokyo',
  'hong-kong': 'Asia/Hong_Kong',
  australia: 'Australia/Sydney',
  canada: 'America/Toronto',
  ireland: 'Europe/Dublin',
  'new-zealand': 'Pacific/Auckland',
  'south-africa': 'Africa/Johannesburg',
  'united-kingdom': 'Europe/London',
};
const utcOffsetByTimezone: Record<string, string> = {
  'Asia/Tokyo': 'UTC+9',
  'Asia/Hong_Kong': 'UTC+8',
  'Australia/Sydney': 'UTC+10/+11',
  'America/Toronto': 'UTC-5/-4',
  'Europe/Dublin': 'UTC+0/+1',
  'Pacific/Auckland': 'UTC+12/+13',
  'Africa/Johannesburg': 'UTC+2',
  'Europe/London': 'UTC+0/+1',
};
const country = getCountries().find((entry) => entry.id === meeting.country_id);
const track = getRacecourseBySlug(meeting.racecourse_id);
const authorityName = authorityNameById[meeting.authority_id] ?? titleCaseId(meeting.authority_id);
const countryName = country?.name_en ?? countryNameById[meeting.country_id] ?? titleCaseId(meeting.country_id);
const countryPath = country ? `/countries/${country.slug}/` : '/countries/';
const trackPath = track ? `/tracks/${track.slug}/` : `/tracks/${meeting.racecourse_id}/`;
const timezone = meetingDetail?.timezone ?? track?.timezone ?? timezoneByCountryId[meeting.country_id] ?? null;
const timezoneLabel = timezone ? `${timezone} (${utcOffsetByTimezone[timezone] ?? 'UTC offset not listed'})` : null;
const timetableRows = meetingDetail?.timetable_rows ?? [];
const hasRaceByRaceTimetable = Boolean(meetingDetail && timetableRows.length > 0);
const hasRaceName = Boolean(meetingDetail?.show_race_name && timetableRows.some((row) => row.race_name));
const hasDistance = Boolean(meetingDetail?.show_distance && timetableRows.some((row) => row.distance_m));
const hasSurface = Boolean(meetingDetail?.show_surface && timetableRows.some((row) => row.surface || row.course_label));
const pageKind = hasRaceByRaceTimetable ? 'Race timetable' : 'Meeting detail';
const effectiveRank = meetingDetail?.effective_public_rank ?? meeting.capability_rank;
const timeCoverageNoteByRank: Record<string, string> = {
  C: 'This record confirms the meeting date and racecourse only. Race times are not available in the current source route.',
  B: 'This record confirms the first race time only. Last race time and race-by-race rows are not available in the current source route.',
  'B+': 'This record confirms first and last race times only. Full race-by-race rows are not available in the current source route.',
  A: 'This public detail includes race-by-race labels and post times only.',
  'A+': 'This public detail includes race-by-race post times and policy-approved minimal programme summary fields.',
};
---

<BaseLayout
  title={`${racecourseName} ${pageKind.toLowerCase()} | Where Horses Run`}
  description="Public-safe meeting detail with official-source link and timetable coverage where available."
  canonicalPath={detailPath}
>
  <nav class="detail-nav" aria-label="Meeting detail navigation">
    <a href="/calendar/">← Calendar</a>
    <a href="/today/">← Today</a>
    <a href="/major-countries/current-timetable/">← Current Timetable</a>
  </nav>

  <section aria-labelledby="page-title">
    <p class="eyebrow">{pageKind}</p>
    <h1 id="page-title"><a href={trackPath}>{racecourseName}</a></h1>
    <p>{meeting.date}</p>
    <p>{authorityName} · <a href={countryPath}>{countryName}</a></p>
    <p>Timezone: {displayValue(timezoneLabel)}</p>
    <p>Public rank: {effectiveRank}</p>
    <p>Capability rank: {meeting.capability_rank}</p>
    <p>Policy: {displayValue(meetingDetail?.policy_id ?? null)}</p>
    <p>Source: {meetingDetail?.source_status ?? meeting.source_status}</p>
    <p>First race: {displayValue(meeting.first_race_time_local)}</p>
    <p>Last race: {displayValue(meeting.last_race_time_local)}</p>
  </section>

  <section aria-labelledby="coverage-title">
    <h2 id="coverage-title">Time coverage</h2>
    <p>{timeCoverageNoteByRank[effectiveRank] ?? timeCoverageNoteByRank.C}</p>
  </section>

  {hasRaceByRaceTimetable && (
    <section aria-labelledby="race-timetable-title">
      <h2 id="race-timetable-title">Race timetable</h2>
      <p>{timetableRows.length} public-safe post times.</p>
      <div class="table-scroll" role="region" aria-label="Race-by-race post time list" tabindex="0">
        <table>
          <thead>
            <tr>
              <th>Race</th>
              <th>Post time</th>
              {hasRaceName && <th>Race name</th>}
              {hasDistance && <th>Distance</th>}
              {hasSurface && <th>Surface / course</th>}
            </tr>
          </thead>
          <tbody>
            {timetableRows.map((row) => (
              <tr>
                <td>{row.label}</td>
                <td>{row.post_time_local}</td>
                {hasRaceName && <td>{displayValue(row.race_name)}</td>}
                {hasDistance && <td>{row.distance_m ? `${row.distance_m}m` : 'Not displayed'}</td>}
                {hasSurface && <td>{[row.surface, row.course_label].filter(Boolean).join(' · ') || 'Not displayed'}</td>}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <section aria-labelledby="official-source-title">
    <h2 id="official-source-title">Official source</h2>
    <p><a href={meetingDetail?.official_source_url ?? meeting.official_source_url}>Open official source</a></p>
    <p>Last checked: {displayValue(meetingDetail?.last_checked_date ?? meeting.last_checked_date)}</p>
  </section>

  <section aria-labelledby="boundary-title">
    <h2 id="boundary-title">Publication boundary</h2>
    <p>This page stores only public-safe timetable fields. Entries, runners, horses, jockeys, trainers, odds, results, payouts, predictions, tips, and raw source pages are not republished here.</p>
  </section>
</BaseLayout>

<style>
  .detail-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-block-end: 2rem;
  }

  .eyebrow {
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  section {
    margin-block-start: 2rem;
  }

  h1,
  h2,
  p {
    margin-block: 0 0.75rem;
  }

  .table-scroll {
    overflow-x: auto;
  }

  table {
    border-collapse: collapse;
    width: 100%;
  }

  th,
  td {
    border-bottom: 1px solid var(--whr-color-border);
    padding: 0.55rem 0.4rem;
    text-align: left;
    vertical-align: top;
  }
</style>
