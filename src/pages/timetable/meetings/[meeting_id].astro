---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getNormalizedTimetableMeetingDetail } from '../../../data/normalizedTimetableMeetingDetails';
import { createNormalizedTimetableMeetingDetailPath } from '../../../data/normalizedTimetableCalendarPreview';
import { getTimetableMeetingRows, type TimetableMeetingRow } from '../../../data/timetableMeetingRows';
import { getCountries, getRacecourseBySlug } from '../../../lib/data';

export function getStaticPaths() {
  const meetings = getTimetableMeetingRows().filter((meeting) => meeting.can_view_race_timetable);

  return meetings.map((meeting) => ({
    params: { meeting_id: meeting.meeting_id },
    props: { meeting },
  }));
}

interface Props {
  meeting: TimetableMeetingRow;
}

const { meeting } = Astro.props;
const meetingDetail = getNormalizedTimetableMeetingDetail(meeting.meeting_id);
const detailPath = createNormalizedTimetableMeetingDetailPath(meeting.meeting_id);
const displayValue = (value: string | null | undefined) => value ?? 'Not displayed';
const titleCaseId = (value: string) =>
  value
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
const racecourseName = meeting.racecourse_name;
const authorityNameById: Record<string, string> = {
  jra: 'Japan Racing Association',
  hkjc: 'Hong Kong Jockey Club',
  'nar-local-government-racing': 'National Association of Racing',
};
const countryNameById: Record<string, string> = {
  japan: 'Japan',
  'hong-kong': 'Hong Kong',
};
const timezoneByCountryId: Record<string, string> = {
  japan: 'Asia/Tokyo',
  'hong-kong': 'Asia/Hong_Kong',
};
const country = getCountries().find((entry) => entry.id === meeting.country_id);
const track = getRacecourseBySlug(meeting.racecourse_id);
const authorityName = authorityNameById[meeting.authority_id] ?? titleCaseId(meeting.authority_id);
const countryName = country?.name_en ?? countryNameById[meeting.country_id] ?? titleCaseId(meeting.country_id);
const countryPath = country ? `/countries/${country.slug}/` : '/countries/';
const trackPath = track ? `/tracks/${track.slug}/` : `/tracks/${meeting.racecourse_id}/`;
const timezone = track?.timezone ?? timezoneByCountryId[meeting.country_id] ?? null;
const timetableRows = meetingDetail?.timetable_rows ?? [];
const hasRaceByRaceTimetable = timetableRows.length > 0;
---

<BaseLayout
  title={`${racecourseName} race timetable | Where Horses Run`}
  description="Public-safe meeting timetable with official-source link and race-by-race post times where available."
  canonicalPath={detailPath}
>
  <nav class="detail-nav" aria-label="Meeting detail navigation">
    <a href="/calendar/">← Calendar</a>
    <a href="/today/">← Today</a>
    <a href="/major-countries/current-timetable/">← Current Timetable</a>
  </nav>

  <section aria-labelledby="page-title">
    <p class="eyebrow">Timetable meeting detail</p>
    <h1 id="page-title"><a href={trackPath}>{racecourseName}</a></h1>
    <p>{meeting.date}</p>
    <p>{authorityName} · <a href={countryPath}>{countryName}</a></p>
    <p>Timezone: {displayValue(timezone)}</p>
    <p>Rank: {meeting.capability_rank}</p>
    <p>Source: {meeting.source_status}</p>
    <p>First race: {displayValue(meeting.first_race_time_local)}</p>
    <p>Last race: {displayValue(meeting.last_race_time_local)}</p>
  </section>

  <section aria-labelledby="race-timetable-title">
    <h2 id="race-timetable-title">Race timetable</h2>
    {hasRaceByRaceTimetable ? (
      <>
        <p>{timetableRows.length} public-safe post times.</p>
        <div class="table-scroll" role="region" aria-label="Race-by-race post time list" tabindex="0">
          <table>
            <thead>
              <tr>
                <th>Race</th>
                <th>Post time</th>
              </tr>
            </thead>
            <tbody>
              {timetableRows.map((row) => (
                <tr>
                  <td>{row.label}</td>
                  <td>{row.post_time_local}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p>{meetingDetail?.summary_note}</p>
      </>
    ) : (
      <p>No public-safe race-by-race post-time list is stored for this meeting.</p>
    )}
  </section>

  <section aria-labelledby="official-source-title">
    <h2 id="official-source-title">Official source</h2>
    <p><a href={meeting.official_source_url}>Open official {meeting.authority_id.toUpperCase()} source</a></p>
    <p>Last checked: {displayValue(meeting.last_checked_date)}</p>
  </section>

  <section aria-labelledby="boundary-title">
    <h2 id="boundary-title">Publication boundary</h2>
    <p>This page stores only public-safe timetable fields. Detailed official information should be confirmed at the official source.</p>
  </section>
</BaseLayout>

<style>
  .detail-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-block-end: 2rem;
  }

  .eyebrow {
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  section {
    margin-block-start: 2rem;
  }

  h1,
  h2,
  p {
    margin-block: 0 0.75rem;
  }

  .table-scroll {
    overflow-x: auto;
  }

  table {
    border-collapse: collapse;
    width: 100%;
  }

  th,
  td {
    border-bottom: 1px solid var(--whr-color-border);
    padding: 0.55rem 0.4rem;
    text-align: left;
  }
</style>
