---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  getPublicTimetableMeetingDetail,
  getPublicTimetableMeetingRows,
  type PublicTimetableMeetingDetail,
  type PublicTimetableMeetingRow,
} from '../../../lib/timetable/publicTimetableViewModel';
import { getCountries, getRacecourses } from '../../../lib/data';

export function getStaticPaths() {
  const meetings = getPublicTimetableMeetingRows().filter((meeting) => meeting.detail_path !== null);

  return meetings.map((meeting) => ({
    params: { meeting_id: meeting.meeting_id },
    props: {
      meeting,
      detail: getPublicTimetableMeetingDetail(meeting.meeting_id),
    },
  }));
}

interface Props {
  meeting: PublicTimetableMeetingRow;
  detail: PublicTimetableMeetingDetail | undefined;
}

const { meeting, detail } = Astro.props;

if (!detail) {
  throw new Error(`Missing public meeting detail for ${meeting.meeting_id}`);
}

const displayValue = (value: string | number | null | undefined) => value ?? 'Not displayed';
const titleCaseId = (value: string) =>
  value
    .replace(/-racecourse$/, '')
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');

const countries = getCountries();
const racecourses = getRacecourses();
const country = countries.find((entry) => entry.id === meeting.country_id);
const track = racecourses.find((entry) => entry.id === meeting.racecourse_id);

const racecourseName = track?.name_en ?? `${titleCaseId(meeting.racecourse_id)} Racecourse`;
const authorityNameById: Record<string, string> = {
  jra: 'Japan Racing Association',
  hkjc: 'Hong Kong Jockey Club',
  'nar-local-government-racing': 'National Association of Racing',
  'banei-tokachi': 'Banei Tokachi',
  'emirates-racing-authority': 'Emirates Racing Authority',
};
const countryName = country?.name_en ?? titleCaseId(meeting.country_id);
const countryPath = country ? `/countries/${country.slug}/` : '/countries/';
const trackPath = track ? `/tracks/${track.slug}/` : `/tracks/${meeting.racecourse_id}/`;
const authorityName = authorityNameById[meeting.authority_id] ?? titleCaseId(meeting.authority_id);

const pageKind = detail.effective_public_rank === 'A+' ? 'Programme summary' : 'Race timetable';
const hasRaceRows = detail.timetable_rows.length > 0;
const hasRaceName = detail.show_race_name && detail.timetable_rows.some((row) => row.race_name);
const hasDistance = detail.show_distance && detail.timetable_rows.some((row) => row.distance_m !== undefined);
const hasSurface = detail.show_surface && detail.timetable_rows.some((row) => row.surface);
const hasCourse = detail.show_course && detail.timetable_rows.some((row) => row.course_label);

const timeCoverageNoteByRank: Record<string, string> = {
  A: 'This public detail page shows race labels and post times only.',
  'A+': 'This public detail page shows race labels, post times, and policy-approved programme summary fields only.',
};
---

<BaseLayout
  title={`${racecourseName} ${pageKind.toLowerCase()} | Where Horses Run`}
  description="Public-safe meeting detail with official-source link and policy-controlled timetable coverage."
  canonicalPath={`/timetable/meetings/${meeting.meeting_id}/`}
>
  <nav class="detail-nav" aria-label="Meeting detail navigation">
    <a href="/calendar/">← Calendar</a>
    <a href="/today/">← Today</a>
    <a href="/major-countries/current-timetable/">← Current Timetable</a>
  </nav>

  <section aria-labelledby="page-title">
    <p class="eyebrow">{pageKind}</p>
    <h1 id="page-title"><a href={trackPath}>{racecourseName}</a></h1>
    <p>{meeting.date}</p>
    <p>{authorityName} · <a href={countryPath}>{countryName}</a></p>
    <p>Timezone: {detail.timezone}</p>
    <p>Capability rank: {detail.capability_rank}</p>
    <p>Public rank: {detail.effective_public_rank}</p>
    <p>Publication policy: {detail.policy_id}</p>
    <p>Source status: {detail.source_status}</p>
  </section>

  <section aria-labelledby="coverage-title">
    <h2 id="coverage-title">Time coverage</h2>
    <p>{timeCoverageNoteByRank[detail.effective_public_rank]}</p>
    <p>Where Horses Run does not reproduce entries, runners, odds, results, payouts, predictions, tips, raw source text, or full racecards.</p>
  </section>

  {hasRaceRows && (
    <section aria-labelledby="race-timetable-title">
      <h2 id="race-timetable-title">{pageKind}</h2>
      <p>{detail.timetable_rows.length} public-safe timetable rows.</p>
      <div class="table-scroll" role="region" aria-label="Public-safe race timetable" tabindex="0">
        <table>
          <thead>
            <tr>
              <th>Race</th>
              <th>Post time</th>
              {hasRaceName && <th>Race name</th>}
              {hasDistance && <th>Distance</th>}
              {hasSurface && <th>Surface</th>}
              {hasCourse && <th>Course</th>}
            </tr>
          </thead>
          <tbody>
            {detail.timetable_rows.map((row) => (
              <tr>
                <td>{row.label}</td>
                <td>{row.post_time_local}</td>
                {hasRaceName && <td>{displayValue(row.race_name)}</td>}
                {hasDistance && <td>{row.distance_m ? `${row.distance_m}m` : 'Not displayed'}</td>}
                {hasSurface && <td>{displayValue(row.surface)}</td>}
                {hasCourse && <td>{displayValue(row.course_label)}</td>}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <section aria-labelledby="official-source-title">
    <h2 id="official-source-title">Official source</h2>
    <p><a href={detail.official_source_url}>Open official source</a></p>
    <p>Last checked: {displayValue(detail.last_checked_date)}</p>
  </section>

  <section aria-labelledby="boundary-title">
    <h2 id="boundary-title">Publication boundary</h2>
    <p>This page uses the public meeting detail dataset. A details show only race label and post time. A+ details show only policy-approved programme summary fields.</p>
    <p>Complete official information should be confirmed at the official source.</p>
  </section>
</BaseLayout>

<style>
  .detail-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-block-end: 2rem;
  }

  .eyebrow {
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  section {
    margin-block-start: 2rem;
  }

  h1,
  h2,
  p {
    margin-block: 0 0.75rem;
  }

  .table-scroll {
    overflow-x: auto;
  }

  table {
    border-collapse: collapse;
    width: 100%;
  }

  th,
  td {
    border-bottom: 1px solid var(--whr-color-border);
    padding: 0.55rem 0.4rem;
    text-align: left;
    vertical-align: top;
  }
</style>
