---
import BaseLayout from '../layouts/BaseLayout.astro';
import CalendarDateStatus from '../components/CalendarDateStatus.astro';
import TimetableMeetingList from '../components/TimetableMeetingList.astro';
import {
  getTimetableDataState,
  getTimetableDateContext,
  getTimetableMeetingRowsForDate,
} from '../data/timetableMeetingRows';

const context = getTimetableDateContext();
const dataState = getTimetableDataState(context);
const todayRecords = getTimetableMeetingRowsForDate(context.today);
---

<BaseLayout
  title={`Today's timetable — ${context.today} | Where Horses Run`}
  description={`Reviewed public meeting information for ${context.today}, resolved in ${context.timeZone}. Official sources remain the final confirmation point.`}
  canonicalPath="/today/"
  alternatePath="/ja/today/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Today</p>
    <h1 id="page-title">Today's timetable</h1>
    <p class="hero__summary">
      Meetings for {context.today} in the {context.timeZone} reference timezone. Rank controls how much timing detail is shown.
    </p>
  </section>

  <CalendarDateStatus context={context} dataState={dataState} />

  <section aria-label="Today meeting list">
    <TimetableMeetingList
      records={todayRecords}
      date={context.today}
      emptyLabel={`No reviewed public meetings are listed for ${context.today}. Check official sources for current information.`}
    />
  </section>
</BaseLayout>
