---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimetableMeetingList from '../components/TimetableMeetingList.astro';
import { getCurrentTimetableDate, getTimetableMeetingRowsForDate } from '../data/timetableMeetingRows';

const currentTimetableDate = getCurrentTimetableDate();
const todayRecords = getTimetableMeetingRowsForDate(currentTimetableDate);
---

<BaseLayout
  title="Today's timetable | Where Horses Run"
  description="Today's meeting list, with one official source link per meeting and race timetable links only where race-by-race times are available."
  canonicalPath="/today/"
  alternatePath="/ja/today/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Today</p>
    <h1 id="page-title">Today's timetable</h1>
    <p class="hero__summary">
      Meetings for {currentTimetableDate}. Rank controls how much timing detail is shown.
    </p>
  </section>

  <section aria-label="Today meeting list">
    <TimetableMeetingList
      records={todayRecords}
      date={currentTimetableDate}
      emptyLabel="No meetings are listed for today yet. Use official source links for final confirmation."
    />
  </section>
</BaseLayout>
