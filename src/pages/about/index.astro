---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About | Where Horses Run"
  description="About Where Horses Run, a static-first guide to official horse racing calendars, tracks, sources, and glossary entries."
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">About</p>
    <h1 id="page-title">About Where Horses Run</h1>
    <p class="hero__summary">
      Where Horses Run is a static-first guide to official horse racing calendars, timetables, tracks, source links, and glossary entries.
    </p>
  </section>

  <section class="section-grid" aria-label="About sections">
    <article class="card">
      <h2>Purpose</h2>
      <p>Help users find country, track, calendar, and source entry points for horse racing around the world.</p>
    </article>
    <article class="card">
      <h2>Source-first</h2>
      <p>The site prioritizes official source links and clear coverage notes.</p>
    </article>
    <article class="card">
      <h2>Current phase</h2>
      <p>This project is in the static MVP phase.</p>
    </article>
  </section>
</BaseLayout>
