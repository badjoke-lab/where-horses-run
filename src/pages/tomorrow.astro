---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimetableMeetingList from '../components/TimetableMeetingList.astro';
import { getTimetableMeetingRowsForDate, getTomorrowTimetableDate } from '../data/timetableMeetingRows';

const tomorrowTimetableDate = getTomorrowTimetableDate();
const tomorrowRecords = getTimetableMeetingRowsForDate(tomorrowTimetableDate);
---

<BaseLayout
  title="Tomorrow's timetable | Where Horses Run"
  description="Tomorrow's meeting list, with one official source link per meeting and race timetable links only where race-by-race times are available."
  canonicalPath="/tomorrow/"
  alternatePath="/ja/tomorrow/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Tomorrow</p>
    <h1 id="page-title">Tomorrow's timetable</h1>
    <p class="hero__summary">
      Meetings for {tomorrowTimetableDate}. Rank controls how much timing detail is shown.
    </p>
  </section>

  <section aria-label="Tomorrow meeting list">
    <TimetableMeetingList
      records={tomorrowRecords}
      date={tomorrowTimetableDate}
      emptyLabel="No meetings are listed for tomorrow yet. Use official source links for final confirmation."
    />
  </section>
</BaseLayout>
