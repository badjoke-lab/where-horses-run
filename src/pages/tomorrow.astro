---
import BaseLayout from '../layouts/BaseLayout.astro';
import CalendarDateStatus from '../components/CalendarDateStatus.astro';
import TimetableMeetingList from '../components/TimetableMeetingList.astro';
import {
  getTimetableDataState,
  getTimetableDateContext,
  getTimetableMeetingRowsForDate,
} from '../data/timetableMeetingRows';

const context = getTimetableDateContext();
const dataState = getTimetableDataState(context);
const tomorrowRecords = getTimetableMeetingRowsForDate(context.tomorrow);
---

<BaseLayout
  title={`Tomorrow's timetable — ${context.tomorrow} | Where Horses Run`}
  description={`Reviewed public meeting information for ${context.tomorrow}, resolved from the ${context.timeZone} reference date.`}
  canonicalPath="/tomorrow/"
  alternatePath="/ja/tomorrow/"
>
  <section class="hero" aria-labelledby="page-title">
    <p class="hero__eyebrow">Tomorrow</p>
    <h1 id="page-title">Tomorrow's timetable</h1>
    <p class="hero__summary">
      Meetings for {context.tomorrow}, the day after the {context.today} reference date in {context.timeZone}.
    </p>
  </section>

  <CalendarDateStatus context={context} dataState={dataState} />

  <section aria-label="Tomorrow meeting list">
    <TimetableMeetingList
      records={tomorrowRecords}
      date={context.tomorrow}
      emptyLabel={`No reviewed public meetings are listed for ${context.tomorrow}. Check official sources for current information.`}
    />
  </section>
</BaseLayout>
