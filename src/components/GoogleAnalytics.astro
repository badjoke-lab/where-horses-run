---
import { siteConfig } from '../lib/siteConfig';

const shouldLoadAnalytics = Astro.url.hostname === 'whr.badjoke-lab.com';
---

{shouldLoadAnalytics && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${siteConfig.gaMeasurementId}`}></script>
    <script is:inline define:vars={{ gaMeasurementId: siteConfig.gaMeasurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaMeasurementId);
    </script>
  </>
)}
