---
import type { TimetableMeetingDayGroup, TimetableMeetingRow } from '../data/timetableMeetingRows';

type Props =
  | {
      groups: TimetableMeetingDayGroup[];
      emptyLabel?: string;
      lang?: 'en' | 'ja';
    }
  | {
      records: TimetableMeetingRow[];
      date?: string;
      emptyLabel?: string;
      lang?: 'en' | 'ja';
    };

const props = Astro.props as Props;
const lang = props.lang ?? 'en';
const emptyLabel = props.emptyLabel ?? (lang === 'ja'
  ? '開催情報はまだありません。最終確認には公式ソースを使用してください。'
  : 'No meetings are listed yet. Use official source links for final confirmation.');
const groups: TimetableMeetingDayGroup[] = 'groups' in props
  ? props.groups
  : [
      {
        date: props.date ?? props.records[0]?.date ?? '',
        records: props.records,
      },
    ].filter((group) => group.records.length > 0);

const text = lang === 'ja'
  ? {
      authority: '主催・体系',
      country: '国・地域',
      detail: '開催詳細',
      first: '第1レース',
      last: '最終レース',
      official: '公式ソース',
      rank: '公開ランク',
      racecourse: '競馬場',
      sourceStatus: 'ソース状態',
      lastChecked: '最終確認',
      notListed: '未掲載',
      sourceRequired: '最終確認は公式ソースで行ってください。',
    }
  : {
      authority: 'Authority / system',
      country: 'Country',
      detail: 'Meeting detail',
      first: 'First race',
      last: 'Last race',
      official: 'Official source',
      rank: 'Public rank',
      racecourse: 'Racecourse',
      sourceStatus: 'Source status',
      lastChecked: 'Last checked',
      notListed: 'Not listed',
      sourceRequired: 'Use the official source for final confirmation.',
    };

const displayTime = (value: string | null) => value ?? text.notListed;
const shouldShowFirst = (record: TimetableMeetingRow) => record.capability_rank !== 'C';
const shouldShowLast = (record: TimetableMeetingRow) =>
  record.capability_rank === 'B+' || record.capability_rank === 'A' || record.capability_rank === 'A+';
---

{groups.length > 0 ? (
  <div class="timetable-date-groups">
    {groups.map((group) => (
      <section class="timetable-date-group" aria-labelledby={`date-${group.date}`}>
        {group.date && <h2 id={`date-${group.date}`}>{group.date}</h2>}
        <ul class="meeting-list" aria-label={group.date ? `${group.date} meetings` : 'Meetings'}>
          {group.records.map((record) => (
            <li class="meeting-card">
              <div class="meeting-card__main">
                <span class="meeting-card__course">{record.racecourse_name}</span>
                <span class="meeting-card__rank">{text.rank}: {record.capability_rank}</span>
              </div>

              <dl class="meeting-card__meta">
                <div>
                  <dt>{text.authority}</dt>
                  <dd>{record.authority_label}</dd>
                </div>
                <div>
                  <dt>{text.country}</dt>
                  <dd>{record.country_label}</dd>
                </div>
                {shouldShowFirst(record) && (
                  <div>
                    <dt>{text.first}</dt>
                    <dd>{displayTime(record.first_race_time_local)}</dd>
                  </div>
                )}
                {shouldShowLast(record) && (
                  <div>
                    <dt>{text.last}</dt>
                    <dd>{displayTime(record.last_race_time_local)}</dd>
                  </div>
                )}
                {record.source_status && (
                  <div>
                    <dt>{text.sourceStatus}</dt>
                    <dd>{record.source_status}</dd>
                  </div>
                )}
                {record.last_checked_date && (
                  <div>
                    <dt>{text.lastChecked}</dt>
                    <dd>{record.last_checked_date}</dd>
                  </div>
                )}
              </dl>

              <div class="meeting-card__links">
                {record.detail_path && <a href={record.detail_path}>{text.detail}</a>}
                <a href={record.official_source_url}>{text.official}</a>
              </div>
              <p class="meeting-card__note">{text.sourceRequired}</p>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
) : (
  <p>{emptyLabel}</p>
)}

<style>
  .timetable-date-groups {
    display: grid;
    gap: 1.75rem;
  }

  .timetable-date-group h2 {
    margin-block-end: 0.75rem;
  }

  .meeting-list {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .meeting-card {
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 0.75rem;
    display: grid;
    gap: 0.65rem;
    padding: 0.85rem;
  }

  .meeting-card__main {
    align-items: baseline;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
    justify-content: space-between;
  }

  .meeting-card__course {
    font-size: 1.05rem;
    font-weight: 700;
  }

  .meeting-card__rank {
    font-size: 0.88rem;
    font-weight: 700;
  }

  .meeting-card__meta {
    display: grid;
    gap: 0.45rem 0.85rem;
    grid-template-columns: repeat(auto-fit, minmax(9.5rem, 1fr));
    margin: 0;
  }

  .meeting-card__meta div {
    min-width: 0;
  }

  .meeting-card__meta dt {
    color: #555;
    font-size: 0.78rem;
    margin: 0;
  }

  .meeting-card__meta dd {
    font-weight: 600;
    margin: 0;
  }

  .meeting-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
  }

  .meeting-card__note {
    color: #555;
    font-size: 0.84rem;
    margin: 0;
  }

  @media (max-width: 420px) {
    .meeting-card {
      border-radius: 0.6rem;
      padding: 0.75rem;
    }

    .meeting-card__meta {
      grid-template-columns: 1fr;
    }
  }
</style>
