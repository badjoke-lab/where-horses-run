---
import type { TimetableMeetingDayGroup, TimetableMeetingRow } from '../data/timetableMeetingRows';

type Props =
  | {
      groups: TimetableMeetingDayGroup[];
      emptyLabel?: string;
      lang?: 'en' | 'ja';
    }
  | {
      records: TimetableMeetingRow[];
      date?: string;
      emptyLabel?: string;
      lang?: 'en' | 'ja';
    };

const props = Astro.props as Props;
const lang = props.lang ?? 'en';
const emptyLabel = props.emptyLabel ?? (lang === 'ja'
  ? '開催情報はまだありません。最終確認には公式ソースを使用してください。'
  : 'No meetings are listed yet. Use official source links for final confirmation.');
const groups: TimetableMeetingDayGroup[] = 'groups' in props
  ? props.groups
  : [
      {
        date: props.date ?? props.records[0]?.date ?? '',
        records: props.records,
      },
    ].filter((group) => group.records.length > 0);

const displayTime = (value: string | null) => value ?? '—';
const detailLabel = (record: TimetableMeetingRow) => {
  if (lang === 'ja') {
    return record.can_view_race_timetable ? 'レース時刻表を見る' : '詳細';
  }
  return record.can_view_race_timetable ? 'View race timetable' : 'Detail';
};
const officialSourceLabel = lang === 'ja' ? '公式ソース' : 'Official source';
const firstLabel = lang === 'ja' ? '第1レース' : 'First';
const lastLabel = lang === 'ja' ? '最終レース' : 'Last';
---

{groups.length > 0 ? (
  <div class="timetable-date-groups">
    {groups.map((group) => (
      <section class="timetable-date-group" aria-labelledby={`date-${group.date}`}>
        {group.date && <h2 id={`date-${group.date}`}>{group.date}</h2>}
        <ul class="meeting-list">
          {group.records.map((record) => (
            <li class="meeting-row">
              <span class="meeting-row__course">{record.racecourse_name}</span>
              <span>{record.authority_label}</span>
              <span>{record.country_label}</span>
              <span>Rank {record.capability_rank}</span>
              {record.capability_rank !== 'C' && (
                <span>{firstLabel}: {displayTime(record.first_race_time_local)}</span>
              )}
              {(record.capability_rank === 'B+' || record.capability_rank === 'A' || record.capability_rank === 'A+') && (
                <span>{lastLabel}: {displayTime(record.last_race_time_local)}</span>
              )}
              {record.detail_path && <a href={record.detail_path}>{detailLabel(record)}</a>}
              <a href={record.official_source_url}>{officialSourceLabel}</a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
) : (
  <p>{emptyLabel}</p>
)}

<style>
  .timetable-date-groups {
    display: grid;
    gap: 1.5rem;
  }

  .timetable-date-group h2 {
    margin-block-end: 0.5rem;
  }

  .meeting-list {
    display: grid;
    gap: 0.45rem;
    list-style: disc;
    margin: 0;
    padding-inline-start: 1.25rem;
  }

  .meeting-row {
    align-items: baseline;
    column-gap: 1rem;
    display: flex;
    flex-wrap: wrap;
    row-gap: 0.25rem;
  }

  .meeting-row__course {
    font-weight: 700;
  }
</style>
