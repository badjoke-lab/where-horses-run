{
  "schema_version": "timetable-candidates-schema-v0",
  "purpose": "Shared candidate JSON contract for safe meeting-level timetable generation before human review and overlay promotion.",
  "required_top_level_fields": [
    "schema_version",
    "generated_at",
    "source_adapter_id",
    "country_id",
    "candidate_window",
    "records",
    "review"
  ],
  "candidate_window": {
    "required_fields": ["start_date", "end_date_exclusive", "timezone"],
    "rules": [
      "start_date and end_date_exclusive use YYYY-MM-DD.",
      "records must be inside the candidate_window.",
      "timezone must be an IANA timezone string."
    ]
  },
  "record_required_fields": [
    "candidate_id",
    "country_id",
    "racing_system_id",
    "racecourse_id",
    "racecourse_name",
    "date",
    "start_time_local",
    "timezone",
    "racing_type",
    "source_id",
    "source_url",
    "source_checked_at",
    "extraction_method",
    "status",
    "confidence",
    "review_status",
    "notes"
  ],
  "allowed_status_values": [
    "candidate",
    "source-reviewed",
    "rejected",
    "promoted"
  ],
  "allowed_review_status_values": [
    "needs_review",
    "approved",
    "rejected"
  ],
  "allowed_extraction_methods": [
    "manual_seed",
    "adapter_dry_run",
    "adapter_candidate",
    "season_gap"
  ],
  "safe_fields_only": [
    "country_id",
    "racing_system_id",
    "racecourse_id",
    "racecourse_name",
    "date",
    "start_time_local",
    "timezone",
    "racing_type",
    "source_id",
    "source_url",
    "source_checked_at",
    "status",
    "confidence",
    "notes"
  ],
  "forbidden_content": [
    "raw HTML",
    "source response body",
    "racecard",
    "entries",
    "horse names",
    "jockey names",
    "trainer names",
    "odds",
    "results",
    "payouts",
    "predictions",
    "tips",
    "betting advice"
  ],
  "promotion_rules": [
    "Only approved candidate records may be promoted to an overlay file.",
    "Rejected records must never be promoted.",
    "Duplicate date/racecourse/source candidates must be resolved before promotion.",
    "Candidate generation must not automatically publish to production-facing overlay files without review.",
    "Official source links remain the final confirmation point."
  ]
}
